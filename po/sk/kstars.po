#: tools/scriptbuilder.cpp:176
#, kde-format
msgid ""
"Point the display at the specified location. %1 can be the name of an "
"object, a cardinal point on the compass, or 'zenith'."
msgstr ""
"Nasmerujte zobrazenie v určenej pozícii. %1 môže byť názov objektu, hlavný "
"smer na kompase alebo 'zenit'."

#: tools/scriptbuilder.cpp:181
#, kde-format
msgid "Add a name label to the object named %1."
msgstr "Pridať popis s menom k objektu s názvom %1."

#: tools/scriptbuilder.cpp:183
#, kde-format
msgid "Remove the name label from the object named %1."
msgstr "Odstrániť popis s menom z objektu s názvom %1."

#: tools/scriptbuilder.cpp:186
#, kde-format
msgid "Add a trail to the solar system body named %1."
msgstr "Pridať dráhu do telesa solárneho systému pomenovaného %1."

#: tools/scriptbuilder.cpp:188
#, kde-format
msgid "Remove the trail from the solar system body named %1."
msgstr "Odstrániť dráhu z telesa solárneho systému pomenovaného %1."

#: tools/scriptbuilder.cpp:191
#, kde-format
msgid ""
"Point the display at the specified RA/Dec coordinates.  RA is expressed in "
"Hours; Dec is expressed in Degrees."
msgstr ""
"Namieriť zobrazenie na určené súradnice RA/Dec. RA je vyjadrená v hodinách; "
"Dec je vyjadrená v stupňoch."

#: tools/scriptbuilder.cpp:196
#, kde-format
msgid ""
"Point the display at the specified Alt/Az coordinates.  Alt and Az are "
"expressed in Degrees."
msgstr ""
"Namieriť zobrazenie na určené súradnice Výš/Az. Výš a Az sú vyjadrené v "
"stupňoch."

#: tools/scriptbuilder.cpp:198
#, kde-format
msgid "Increase the display Zoom Level."
msgstr "Zvýšiť úroveň zobrazenia priblíženia."

#: tools/scriptbuilder.cpp:199
#, kde-format
msgid "Decrease the display Zoom Level."
msgstr "Znížiť úroveň zobrazenia priblíženia."

#: tools/scriptbuilder.cpp:201
#, kde-format
msgid "Set the display Zoom Level to its default value."
msgstr "Nastaviť úroveň priblíženia zobrazenia na jeho predvolenú hodnotu."

#: tools/scriptbuilder.cpp:203
#, kde-format
msgid "Set the display Zoom Level manually."
msgstr "Nastaviť úroveň priblíženia zobrazenia ručne."

#: tools/scriptbuilder.cpp:205
#, kde-format
msgid "Set the system clock to the specified Local Time."
msgstr "Nastaviť systémové hodina na určený miestny čas."

#: tools/scriptbuilder.cpp:208
#, kde-format
msgid "Pause script execution for specified number of seconds."
msgstr "Pozastaviť vykonávania skriptu na určený počet sekúnd."

#: tools/scriptbuilder.cpp:210
#, kde-format
msgid ""
"Halt script execution until the specified key is pressed.  Only single-key "
"strokes are possible; use 'space' for the spacebar."
msgstr ""
"Zastaviť vykonávania skriptu, kým nie stlačený určený kláves. Možné je "
"stlačenie iba jednotlivého klávesu; použiť 'space' pre medzerník."

#: tools/scriptbuilder.cpp:214
#, kde-format
msgid "Set whether the display is tracking the current location."
msgstr "Nastaviť, či zobrazenie sleduje aktuálnu pozíciu."

#: tools/scriptbuilder.cpp:216
#, kde-format
msgid "Change view option named %1 to value %2."
msgstr "Zmeniť voľbu pohľadu nazvanú %1 na hodnotu %2."

#: tools/scriptbuilder.cpp:219
#, kde-format
msgid ""
"Set the geographic location to the city specified by city, province and "
"country."
msgstr ""
"Nastaviť zemepisnú polohu na mesto určené podľa mesta, oblasti a krajiny."

#: tools/scriptbuilder.cpp:222
#, kde-format
msgid "Set the color named %1 to the value %2."
msgstr "Nastaviť farbu s názvom %1 k hodnote %2."

#: tools/scriptbuilder.cpp:224
#, kde-format
msgid "Load the color scheme specified by name."
msgstr "Načítať farebnú schému určenú menom."

#: tools/scriptbuilder.cpp:227
#, kde-format
msgid "Export the sky image to the file, with specified width and height."
msgstr "Exportovať obrázok oblohy do súboru s určenou šírkou a výškou."

#: tools/scriptbuilder.cpp:231
#, kde-format
msgid ""
"Print the sky image to a printer or file.  If %1 is true, it will show the "
"print dialog.  If %2 is true, it will use the Star Chart color scheme for "
"printing."
msgstr ""
"Vytlačiť obrázok oblohy na tlačiareň alebo do súboru. Pokiaľ je %1 pravda, "
"ukáže sa dialógové okno tlače. Ak je %2 pravda, použije sa farebná schéma "
"Hviezdna mapa pre tlač."

#: tools/scriptbuilder.cpp:235
#, kde-format
msgid "Halt the simulation clock."
msgstr "Zastaviť simulačné hodiny."

#: tools/scriptbuilder.cpp:236
#, kde-format
msgid "Start the simulation clock."
msgstr "Spustiť simulačné hodiny."

#: tools/scriptbuilder.cpp:238
#, kde-format
msgid ""
"Set the timescale of the simulation clock to specified scale.  1.0 means "
"real-time; 2.0 means twice real-time; etc."
msgstr ""
"Nastaviť časovú mieru simulačných hodín pre určený rozsah. 1.0 znamená "
"reálny čas; 2.0 znamená dvojnásobok reálneho času; atď."

