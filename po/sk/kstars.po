msgstr "Zobrazovať NumStars na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeSkyBg), group (Analyze)
#: kstars.kcfg:3647
#, kde-format
msgid "Display SkyBackground on the Analyze Statistics Plot."
msgstr "Zobrazovať SkyBackground na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeSNR), group (Analyze)
#: kstars.kcfg:3651
#, kde-format
