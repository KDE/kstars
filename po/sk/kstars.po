#. i18n: ectx: property (toolTip), widget (QLabel, label_3)
#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_DitherMaxIterations)
#: ekos/guide/opsdither.ui:187 ekos/guide/opsdither.ui:197
#, kde-format
msgid ""
"<html><head/><body><p>Maximum dithering iteration attempts before giving up</"
"p></body></html>"
msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_3)
#: ekos/guide/opsdither.ui:190
#, kde-format
msgid "Max. Iterations"
msgstr "Max. iterácií"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_DitherWithOnePulse)
#: ekos/guide/opsdither.ui:212
#, kde-format
msgid ""
"<html><head/><body><p>If checked, dithering amount is randomly generated, "
"pulses are sent, but the resultant pixel dithering amount is not enforced so "
"only the one dither pulse is sent. This is quicker, and recommended as "
"dither amount is random anyway. It is necessary when 2-D dither is required "
"but guiding is only done in one axis.</p></body></html>"
msgstr ""
"<html><head/><body><p>Ak je zaškrtnuté, množstvo rozptyľovania sa generuje "
"náhodne, impulzy sa odosielajú, ale výsledné množstvo rozptyľovania v "
"pixeloch sa nevynucuje, takže sa odošle len jeden rozptyľovací impulz. Je to "
"rýchlejšie a odporúčané, keďže množstvo rozptyľovania je aj tak náhodné. Je "
"nevyhnutné, keď je potrebné 2D rozptyľovanie, ale vedenie prebieha len v "
"jednej osi.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_DitherWithOnePulse)
#: ekos/guide/opsdither.ui:215
#, kde-format
msgid "One Pulse Dither"
msgstr "Jednoimpulzné rozptyľovanie"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_DitherFailAbortsAutoGuide)
#: ekos/guide/opsdither.ui:222
#, kde-format
msgid ""
"<html><head/><body><p>If checked, autoguiding is aborted when dithering "
"fails. Otherwise, guiding resumes normally.</p></body></html>"
msgstr "<html><head/><body><p>Preemptívne hodiny vypnutia</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_DitherFailAbortsAutoGuide)
#: ekos/guide/opsdither.ui:225
#, kde-format
msgid "Abort Autoguide on failure"
msgstr "Zrušiť automatické vedenie pri zlyhaní"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_DitherNoGuiding)
#: ekos/guide/opsdither.ui:234
#, kde-format
msgid ""
"<html><head/><body><p>Perform dithering when not guiding.</p></body></html>"
msgstr "<html><head/><body><p>Preemptívne hodiny vypnutia</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_DitherNoGuiding)
#: ekos/guide/opsdither.ui:237
#, kde-format
msgid "Non-Guide Dither Pulse"
msgstr "Impulz rozptyľovania bez vedenia"

#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_DitherNoGuidingPulse)
#: ekos/guide/opsdither.ui:244
#, kde-format
msgid ""
"Pulse length in milliseconds to command mount motion in a random direction"
msgstr ""
"Dĺžka impulzu v milisekundách na príkaz pohybu montáže v náhodnom smere"

#. i18n: ectx: property (text), widget (QLabel, label_10)
#: ekos/guide/opsdither.ui:260
#, kde-format
msgid "ms"
msgstr "ms"

#. i18n: ectx: property (text), widget (QLabel, label)
#: ekos/guide/opsgpg.ui:64
#, kde-format
msgid ""
"<html><head/><body><p><a href=\"https://ieeexplore.ieee.org/"
"document/7105398\"><span style=\" text-decoration: underline; color:#007af4;"
"\">The Gaussian Process Guider</span></a>, <span style=\" font-style:italic;"
"\">(c) 2014-2017 Max Planck Society</span>, is used for RA guiding only. "
"Most parameters <br/>can stay at their defaults. <span style=\" font-"
"weight:600; color:#8ae234;\">Enable GPG</span> with the checkbox below. It "
"can be used with all Guide star-detection<br/>algorithms but has been tested "
"most and is recommended with <span style=\" font-weight:600; color:#8ae234;"
"\">SEP MultiStar</span>. It combines a reactive<br/>correction whose "
"aggressiveness is controlled with <span style=\" font-weight:600; color:"
"#8ae234;\">Control Gain</span> and <span style=\" font-weight:600; color:"
"#8ae234;\">Minimum Move</span>, with a predictive<br/>correction controlled "
"by <span style=\" font-weight:600; color:#8ae234;\">Prediction Gain</span>.</"
"p><p>The most important parameter is <span style=\" font-weight:600; color:"
"#8ae234;\">Major Period</span>. If you can determine it for your mount, it's "
"much <br/>better to set it yourself and uncheck <span style=\" font-"
"weight:600; color:#8ae234;\">Estimate Period.</span></p><hr/></body></html>"
msgstr ""
"<html><head/><body><p><a href=\"https://ieeexplore.ieee.org/"
"document/7105398\"><span style=\" text-decoration: underline; color:#007af4;"
"\">Gaussov procesový vodič</span></a>, <span style=\" font-style:italic;"
"\">(c) 2014-2017 Max Planck Society</span>, sa používa len pre vedenie RA. "
"Väčšina parametrov<br/>môže ostať na predvolených hodnotách. <span style=\" "
"font-weight:600; color:#8ae234;\">Povoľte GPG</span> zaškrtávacím políčkom "
"nižšie. Môže byť použitý so všetkými algoritmami detekcie<br/>vodiacich "
"hviezd, ale bol najviac testovaný a odporúčaný s <span style=\" font-"
"weight:600; color:#8ae234;\">SEP MultiStar</span>. Kombinuje reaktívnu<br/"
">korekciu, ktorej agresivita je riadená pomocou <span style=\" font-"
"weight:600; color:#8ae234;\">Gain riadenia</span> a <span style=\" font-"
"weight:600; color:#8ae234;\">Minimálneho pohybu</span>, s prediktívnou<br/"
">korekciou riadenou pomocou <span style=\" font-weight:600; color:#8ae234;"
"\">Gain predpovede</span>.</p><p>Najdôležitejší parameter je <span style=\" "
"font-weight:600; color:#8ae234;\">Hlavná perióda</span>. Ak ju môžete určiť "
"pre vašu montáž, je oveľa<br/>lepšie nastaviť ju sami a odznačiť <span style="
"\" font-weight:600; color:#8ae234;\">Odhadnúť periódu.</span></p><hr/></"
"body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpg0)
#: ekos/guide/opsgpg.ui:81
#, kde-format
msgid "Enable GPG on the Guide tab, using the RA Guiding Algorithm pulldown"
msgstr ""
"Povoliť GPG na karte Vedenie pomocou rozbaľovacieho zoznamu algoritmu "
"vedenia RA"

#. i18n: ectx: property (toolTip), widget (QLabel, label_4)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_GPGDarkGuidingInterval)
#: ekos/guide/opsgpg.ui:119 ekos/guide/opsgpg.ui:280
#, kde-format
msgid ""
"Maximum time between emitting predictive corrections while capturing guide "
"images. This might be on the order of 1 second or less, with the guide "
"exposure much longer. The exact values and the ratio between them will "
"depend greatly on your mount and environmental conditions; but generally, "
"the worse periodic error of your mount, the greater the ratio between guide "
"exposure and dark guiding interval."
msgstr ""
"Maximálny čas medzi vydávaním prediktívnych korekcií počas snímania snímok "
"vodiča. Môže byť v rádoch 1 sekundy alebo menej, pri oveľa dlhšej expozícii "
"vodiča. Presné hodnoty a ich pomer budú vo veľkej miere závisieť od vašej "
"montáže a podmienok prostredia; všeobecne platí, že čím horšia periodická "
"chyba vašej montáže, tým väčší pomer medzi expozíciou vodiča a intervalom "
"tmavého vedenia."

#. i18n: ectx: property (text), widget (QLabel, label_4)
#: ekos/guide/opsgpg.ui:122
#, kde-format
msgid "Dark guiding interval"
msgstr "Interval tmavého vedenia"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgs0a)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_GPGPeriod)
#: ekos/guide/opsgpg.ui:136 ekos/guide/opsgpg.ui:173
#, kde-format
msgid ""
"The length in seconds of the mount's major period (that's being corrected)."
msgstr "Dĺžka v sekundách hlavnej periódy montáže (ktorá sa koriguje)."

#. i18n: ectx: property (text), widget (QLabel, label_gpgs0a)
#: ekos/guide/opsgpg.ui:139
#, kde-format
msgid "Major Period"
msgstr "Hlavné obdobie"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgs2a)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_GPGpWeight)
#: ekos/guide/opsgpg.ui:146 ekos/guide/opsgpg.ui:264
#, kde-format
msgid "The fraction of its prediction the GPG uses to move the mount."
msgstr "Podiel predikcie, ktorý GPG používa na pohyb montáže."

#. i18n: ectx: property (text), widget (QLabel, label_gpgs2a)
#: ekos/guide/opsgpg.ui:149
#, kde-format
msgid "Prediction Gain"
msgstr "Zisk predikcie"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgsDarkGuiding)
#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_GPGDarkGuiding)
#: ekos/guide/opsgpg.ui:156 ekos/guide/opsgpg.ui:244
#, kde-format
msgid "Enable predictive corrections during acquisition of guide camera images"
msgstr "Povoliť prediktívne korekcie počas snímania snímok kamery vodiča"

#. i18n: ectx: property (text), widget (QLabel, label_gpgsDarkGuiding)
#: ekos/guide/opsgpg.ui:159
#, kde-format
msgid "Intra-frame dark guiding"
msgstr "Vnútroznímkové tmavé vedenie"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgs1a)
#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_GPGEstimatePeriod)
#: ekos/guide/opsgpg.ui:186 ekos/guide/opsgpg.ui:215
#, kde-format
msgid ""
"If checked, the GPG estimates the mount's major period. Otherwise, it uses "
"the entry above."
msgstr ""
"Ak je zaškrtnuté, GPG odhadne hlavnú periódu montáže. V opačnom prípade "
"použije hodnotu vyššie."

#. i18n: ectx: property (text), widget (QLabel, label_gpgs1a)
#: ekos/guide/opsgpg.ui:189
#, kde-format
msgid "Estimate Period"
msgstr "Odhadnúť periódu"

#. i18n: ectx: property (text), widget (QLabel, label_2)
#: ekos/guide/opsgpg.ui:208
#, kde-format
msgid "Uses RA \"Aggressiveness\" from Guide controls"
msgstr "Používa \"Agresivitu\" RA z ovládacích prvkov vedenia"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgs4a)
#: ekos/guide/opsgpg.ui:222
#, kde-format
msgid ""
"The min-move parameter the GPG uses to move the mount when it uses its "
"backoff proportional guider."
msgstr ""
"Parameter minimálneho posunu, ktorý GPG používa na pohyb montáže pri použití "
"svojho proporcionálneho vodiča so spätným krokom."

#. i18n: ectx: property (text), widget (QLabel, label_gpgs4a)
#: ekos/guide/opsgpg.ui:225
#, kde-format
msgid "Minimum Move"
msgstr "Minimálny impulz"

#. i18n: ectx: property (text), widget (QLabel, label_3)
#: ekos/guide/opsgpg.ui:237
#, kde-format
msgid "Uses RA \"Min error\" from Guide controls"
msgstr "Používa \"Min. chybu\" RA z ovládacích prvkov vedenia"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgs3a)
#: ekos/guide/opsgpg.ui:254
#, kde-format
msgid ""
"The fraction of the guide-star drift that the GPG uses to move the mount."
msgstr ""
"Stratená stopa vodiacej hviezdy. Skúsiť zvýšiť veľkosť štvorca a "
"skontrolovať pripevnenie."

#. i18n: ectx: property (text), widget (QLabel, label_gpgs3a)
#: ekos/guide/opsgpg.ui:257
#, kde-format
msgid "Control Gain"
msgstr "Zosilnenie riadenia"

#. i18n: ectx: property (title), widget (QGroupBox, expertGroupBox)
#: ekos/guide/opsgpg.ui:308
#, kde-format
msgid "Expert Settings"
msgstr "Expertné nastavenia"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas0a)
#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_GPGSE0KLengthScale)
#: ekos/guide/opsgpg.ui:342 ekos/guide/opsgpg.ui:360
#, kde-format
msgid ""
"<html><head/><body><p>Length scale of the long range kernel in seconds.</"
"p><p>This \n"
"          parameter accounts for the long-term drift in periodic error, on "
"the scale of several major periods. This might be due to, for\n"
"          example:</p><ul style=\"margin-top: 0px; margin-bottom: 0px; "
"margin-left: 0px; margin-right: 0px; -qt-list-indent:\n"
"          1;\"><li style=\" margin-top:12px; margin-bottom:0px; margin-"
"left:0px; margin-right:0px; -qt-block-indent:0;\n"
"          text-indent:0px;\">Harmonic interaction between the gears in the "
"whole gear train,</li><li style=\"\n"
"          margin-top:12px; margin-bottom:0px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0; text-indent:0px;\">Change in\n"
"          loading due to gravity,</li><li style=\" margin-top:12px; margin-"
"bottom:0px; margin-left:0px; margin-right:0px;\n"
"          -qt-block-indent:0; text-indent:0px;\">Thermal variations.</li></"
"ul><p>This should probably be several\n"
"          times larger than the major period.</p></body></html>"
msgstr ""
"<html><head/><body><p>Merítko dĺžky jadrového funkcie dlhého dosahu v "
"sekundách.</p><p>Tento\n"
"          parameter zohľadňuje dlhodobý drift v periodickej chybe, na škále "
"niekoľkých hlavných periód. Môže to byť spôsobené napríklad:</p><ul style="
"\"margin-top: 0px; margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -"
"qt-list-indent:\n"
"          1;\"><li style=\" margin-top:12px; margin-bottom:0px; margin-"
"left:0px; margin-right:0px; -qt-block-indent:0;\n"
"          text-indent:0px;\">Harmonické interakcie medzi ozubenými kolesami "
"v celom prevodovom ústrojenstve,</li><li style=\"\n"
"          margin-top:12px; margin-bottom:0px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0; text-indent:0px;\">Zmeny\n"
"          zaťaženia v dôsledku gravitácie,</li><li style=\" margin-top:12px; "
"margin-bottom:0px; margin-left:0px; margin-right:0px;\n"
"          -qt-block-indent:0; text-indent:0px;\">Tepelné variácie.</li></"
"ul><p>Toto by malo byť pravdepodobne niekoľkonásobne\n"
"          väčšie ako hlavná perióda.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas0a)
#: ekos/guide/opsgpg.ui:345
#, kde-format
msgid "Long-range Length Scale"
msgstr "Dlhodobá dĺžková mierka"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas1a)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_GPGSE0KSignalVariance)
#: ekos/guide/opsgpg.ui:382 ekos/guide/opsgpg.ui:394
#, kde-format
msgid ""
"<html><head/><body><p>Long-range kernel signal variance.</p><p>This "
"describes how \n"
"          much the error changes over the long-term time scale. A higher "
"variance means a larger change in error, on\n"
"          average.</p></body></html>"
msgstr ""
"<html><head/><body><p>Rozptyl signálu jadrového funkcie dlhého dosahu.</"
"p><p>Popisuje, ako veľmi sa chyba mení v dlhodobom časovom meradle. Vyšší "
"rozptyl znamená väčšiu zmenu chyby v priemere.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas1a)
#: ekos/guide/opsgpg.ui:385
#, kde-format
msgid "Long-range Variance"
msgstr "Dlhodobá variancia"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas2a)
#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_GPGPKLengthScale)
#: ekos/guide/opsgpg.ui:420 ekos/guide/opsgpg.ui:433
#, kde-format
msgid ""
"<html><head/><body><p>Periodic Kernel length scale, in seconds.</p><p>This \n"
"          describes how quickly the error changes within a single period. It "
"can be thought of as the wavelength of the noise component\n"
"          above which the noise becomes unpredictable. A higher length scale "
"means the predictable error has less high-frequency\n"
"          components; a shorter length-scale means it has more.</p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Merítko dĺžky periodického jadra v sekundách.</"
"p><p>Popisuje, ako rýchlo sa chyba mení v rámci jednej periódy. Možno to "
"chápať ako vlnovú dĺžku šumovej zložky, nad ktorou sa šum stáva "
"nepredvídateľným. Vyššie merítko dĺžky znamená, že predvídateľná chyba má "
"menej vysokofrekvenčných zložiek; kratšie merítko dĺžky znamená, že ich má "
"viac.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas2a)
#: ekos/guide/opsgpg.ui:423
#, kde-format
msgid "Periodic Length Scale"
msgstr "Periodická dĺžková mierka"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas3a)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_GPGPKSignalVariance)
#: ekos/guide/opsgpg.ui:454 ekos/guide/opsgpg.ui:465
#, kde-format
msgid ""
"<html><head/><body><p>Periodic kernel signal variance.</p><p>This describes "
"how \n"
"          much the error changes during the periodic length scale.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Rozptyl signálu periodického jadra.</p><p>Popisuje, "
"ako veľmi sa chyba mení počas periodického merítka dĺžky.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas3a)
#: ekos/guide/opsgpg.ui:457
#, kde-format
msgid "Periodic Variance"
msgstr "Periodická odchýlka"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas4a)
#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_GPGSE1KLengthScale)
#: ekos/guide/opsgpg.ui:497 ekos/guide/opsgpg.ui:516
#, kde-format
msgid ""
"<html><head/><body><p>Length scale of the short-range kernel in \n"
"          seconds.</p><p>This is a measure of the scale of the non-periodic "
"short-term noise, caused by things such\n"
"          as:</p><ul style=\"margin-top: 0px; margin-bottom: 0px; margin-"
"left: 0px; margin-right: 0px; -qt-list-indent:\n"
"          1;\"><li style=\" margin-top:12px; margin-bottom:12px; margin-"
"left:0px; margin-right:0px; -qt-block-indent:0;\n"
"          text-indent:0px;\">Grit in the gearchain,</li><li style=\" margin-"
"top:12px; margin-bottom:12px;\n"
"          margin-left:0px; margin-right:0px; -qt-block-indent:0; text-"
"indent:0px;\">Wind gusts,</li><li style=\"\n"
"          margin-top:12px; margin-bottom:12px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0;\n"
"          text-indent:0px;\">Structural vibrations, such as footsteps or "
"traffic,</li><li style=\" margin-top:12px;\n"
"          margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-"
"indent:0; text-indent:0px;\">Swinging or dragging\n"
"          cables.</li></ul></body></html>"
msgstr ""
"<html><head/><body><p>Merítko dĺžky jadrového funkcie krátkeho dosahu v\n"
"          sekundách.</p><p>Toto je miera škály neperiodického krátkodobého "
"šumu spôsobeného vecami ako:</p><ul style=\"margin-top: 0px; margin-bottom: "
"0px; margin-left: 0px; margin-right: 0px; -qt-list-indent:\n"
"          1;\"><li style=\" margin-top:12px; margin-bottom:12px; margin-"
"left:0px; margin-right:0px; -qt-block-indent:0;\n"
"          text-indent:0px;\">Nečistoty v prevodovom reťazci,</li><li style="
"\" margin-top:12px; margin-bottom:12px;\n"
"          margin-left:0px; margin-right:0px; -qt-block-indent:0; text-"
"indent:0px;\">Poryvy vetra,</li><li style=\"\n"
"          margin-top:12px; margin-bottom:12px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0;\n"
"          text-indent:0px;\">Štrukturálne vibrácie, ako sú kroky alebo "
"premávka,</li><li style=\" margin-top:12px;\n"
"          margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-"
"indent:0; text-indent:0px;\">Hojdajúce sa alebo ťahané\n"
"          káble.</li></ul></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas4a)
#: ekos/guide/opsgpg.ui:500
#, kde-format
msgid "Short-range Length Scale"
msgstr "Krátkodobá dĺžková mierka"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas5a)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_GPGSE1KSignalVariance)
#: ekos/guide/opsgpg.ui:538 ekos/guide/opsgpg.ui:550
#, kde-format
msgid ""
"<html><head/><body><p>Short-range kernel signal \n"
"          variance.</p><p><br/></p><p>How much the short-range noise changes "
"in the short-term length\n"
"          scale.</p></body></html>"
msgstr ""
"<html><head/><body><p>Rozptyl signálu jadra krátkeho dosahu.</p><p><br/></"
"p><p>Ako veľmi sa krátkodosahový šum mení v krátkodobom merítku dĺžky.</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas5a)
#: ekos/guide/opsgpg.ui:541
#, kde-format
msgid "Short-range Variance"
msgstr "Krátkodobá variancia"

#. i18n: ectx: property (toolTip), widget (QLabel, label_gpgas6a)
#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_GPGPointsForApproximation)
#: ekos/guide/opsgpg.ui:573 ekos/guide/opsgpg.ui:583
#, kde-format
msgid "Number of points used in the Gaussian Process approximation"
msgstr "Počet bodov použitých v gaussovskej procesovej aproximácii"

#. i18n: ectx: property (text), widget (QLabel, label_gpgas6a)
#: ekos/guide/opsgpg.ui:576
#, kde-format
