msgstr "Časový limit obnovenia riešiteľa vypršal: %1s"

#: ekos/align/polaralignmentassistant.cpp:201
#, kde-format
msgid "Refresh solver failed: %1s"
msgstr "Obnovenie riešiteľa zlyhalo: %1s"

#: ekos/align/polaralignmentassistant.cpp:591
#, kde-format
msgid "PAA: Solver failed, retrying."
msgstr "PAA: Riešiteľ zlyhal, skúšam znova."

#: ekos/align/polaralignmentassistant.cpp:598
#, kde-format
msgid "PAA: Stopping, solver failed too many times."
msgstr "PAA: Zastavujem, riešiteľ zlyhal príliš veľakrát."

#: ekos/align/polaralignmentassistant.cpp:637
#, kde-format
msgid "Mount first rotation is complete."
msgstr "Prvé otočenie montáže je dokončené."

#: ekos/align/polaralignmentassistant.cpp:644
#, kde-format
msgid "Mount second rotation is complete."
msgstr "Druhé otočenie montáže je dokončené."

#: ekos/align/polaralignmentassistant.cpp:690
#, kde-format
msgid "Mount aborted. Reverse RA axis direction and try again."
msgstr "Montáž bola prerušená. Otočte smer osi RA a skúste znova."

#: ekos/align/polaralignmentassistant.cpp:779
#, kde-format
msgid ""
"Warning: Equatorial Grid Lines will not be drawn due to limited resources "
"mode."
msgstr ""
"Upozornenie: Čiary ekvatoriálnej mriežky nebudú nakreslené kvôli režimu "
"obmedzených zdrojov."

#: ekos/align/polaralignmentassistant.cpp:783
#, kde-format
msgid "Clearing mount Alignment Model..."
msgstr "Čistenie modelu zarovnania montáže..."

#: ekos/align/polaralignmentassistant.cpp:824
#, kde-format
msgid "This could cause the telescope to cross the meridian."
msgstr "Toto by mohlo spôsobiť, že ďalekohľad prekročí meridián."

#: ekos/align/polaralignmentassistant.cpp:886
#, kde-format
msgid "Parking the mount..."
msgstr "Parkovanie montáže..."

#: ekos/align/polaralignmentassistant.cpp:929
#, kde-format
msgid "Please wait until mount completes rotating to RA (%1) DE (%2)"
msgstr "Počkajte, kým montáž dokončí otáčanie na RA (%1) DEC (%2)"

#: ekos/align/polaralignmentassistant.cpp:945
#: ekos/align/polaralignmentassistant.cpp:951
#, kde-format
msgid "PAA: Failed to findCorrectedPixel."
msgstr "PAA: Nepodarilo sa nájsť opravený pixel."

#: ekos/align/polaralignmentassistant.cpp:977
#, kde-format
msgid "PAA: Failed to find RA Axis center."
msgstr "PAA: Nepodarilo sa nájsť stred osi RA."

#: ekos/align/polaralignmentassistant.cpp:1049
#, kde-format
msgid ""
"Polar-alignment star cannot be updated during refresh phase as it might "
"affect error measurements."
msgstr ""
"Hviezda polárneho zarovnania sa nedá aktualizovať počas fázy obnovy, pretože "
"by to mohlo ovplyvniť merania chýb."

#: ekos/align/polaralignmentassistant.cpp:1066
#, kde-format
msgid "First manual rotation done."
msgstr "Prvé ručné otočenie dokončené."

#: ekos/align/polaralignmentassistant.cpp:1071
#, kde-format
msgid "Second manual rotation done."
msgstr "Druhá manuálna rotácia dokončená."

#: ekos/align/polaralignmentassistant.cpp:1137
#, kde-format
msgid ""
"Mount is synced to celestial pole. You can now continue Polar Alignment "
"Assistant procedure."
msgstr ""
"Montáž je synchronizovaná s nebeským pólom. Teraz môžete pokračovať v "
"postupe pomocníka polárneho zarovnania."

#: ekos/align/polaralignmentassistant.cpp:1156
#, kde-format
msgid "Please wait while WCS data is processed..."
msgstr "Počkajte, prosím, počas spracovania údajov WCS..."

#: ekos/align/polaralignmentassistant.cpp:1187
#, kde-format
msgid "WCS data processing is complete."
msgstr "Spracovanie údajov WCS je dokončené."

#: ekos/align/polaralignmentassistant.cpp:1196
#, kde-format
msgid "WCS info is now valid. Capturing next frame..."
msgstr "Informácie WCS sú teraz platné. Sníma sa ďalší rámec..."

#: ekos/align/polaralignmentassistant.cpp:1238
#, kde-format
msgid "Failed to process World Coordinate System: %1. Try again."
msgstr "Nepodarilo sa spracovať svetový súradnicový systém: %1. Skúste znova."

#: ekos/align/polaralignmentassistant.cpp:1256
#, kde-format
msgid "PAA: Failed to find the RA axis. Quitting."
msgstr "PAA: Nepodarilo sa nájsť os RA. Ukončujem."

#. i18n: ectx: property (text), widget (QLabel, PAHMessageText)
#: ekos/align/polaralignmentassistant.cpp:1287
#: ekos/align/polaralignmentassistant.ui:216
#, kde-format
msgid ""
"<p>The assistant requires three images to find a solution.  Ekos is now "
"capturing the first image...</p>"
msgstr ""
"<p>Pomocník vyžaduje tri snímky na nájdenie riešenia. Ekos teraz sníma prvú "
"snímku...</p>"

#: ekos/align/polaralignmentassistant.cpp:1289
#, kde-format
msgid "<p>Solving the <i>first</i> image...</p>"
msgstr "<p>Riešim <i>prvý</i> obrázok...</p>"

#: ekos/align/polaralignmentassistant.cpp:1291
#, kde-format
msgid "<p>Executing the <i>first</i> mount rotation...</p>"
msgstr "<p>Vykonávam <i>prvé</i> otočenie montáže...</p>"

#: ekos/align/polaralignmentassistant.cpp:1293
#, kde-format
msgid "<p>Settling after the <i>first</i> mount rotation.</p>"
msgstr "<p>Ustálenie po <i>prvom</i> otočení montáže.</p>"

#: ekos/align/polaralignmentassistant.cpp:1295
#, kde-format
msgid "<p>Settling after the <i>second</i> mount rotation.</p>"
msgstr "<p>Ustáľujem po <i>druhom</i> otočení montáže.</p>"

#: ekos/align/polaralignmentassistant.cpp:1297
#, kde-format
msgid "<p>Capturing the second image...</p>"
msgstr "<p>Snímam druhý obrázok...</p>"

#: ekos/align/polaralignmentassistant.cpp:1299
#, kde-format
msgid "<p>Solving the <i>second</i> image...</p>"
msgstr "<p>Riešim <i>druhý</i> obrázok...</p>"

#: ekos/align/polaralignmentassistant.cpp:1301
#, kde-format
msgid "<p>Executing the <i>second</i> mount rotation...</p>"
msgstr "<p>Vykonávam <i>druhé</i> otočenie montáže...</p>"

#: ekos/align/polaralignmentassistant.cpp:1303
#, kde-format
msgid "<p>Capturing the <i>third</i> and final image...</p>"
msgstr "<p>Snímam <i>tretí</i> a posledný obrázok...</p>"

#: ekos/align/polaralignmentassistant.cpp:1305
#, kde-format
msgid "<p>Solving the <i>third</i> image...</p>"
msgstr "<p>Riešim <i>tretí</i> obrázok...</p>"

#: ekos/align/polaralignmentassistant.cpp:1308
#, kde-format
msgid ""
"<p>Choose your exposure time & select an adjustment method. Then click "
"<i>refresh</i> to begin adjustments.</p>"
msgstr ""
"<p>Vyberte čas expozície a zvoľte metódu úpravy. Potom kliknite na "
"<i>obnoviť</i> na začatie úprav.</p>"

#: ekos/align/polaralignmentassistant.cpp:1310
#, kde-format
msgid ""
"<p>Choose your exposure time & select an adjustment method. Click "
"<i>Refresh</i> to begin.</p><p>Correction triangle is plotted above. <i>Zoom "
"in and select a bright star</i> to reposition the correction vector. Use the "
"<i>MoveStar & Calc Error</i> method to estimate the remaining error.</p>"
msgstr ""
"<p>Vyberte čas expozície a zvoľte metódu úpravy. Kliknite na <i>Obnoviť</i> "
"na začatie.</p><p>Korekčný trojuholník je zobrazený vyššie. <i>Priblížte a "
"vyberte jasnú hviezdu</i> na presunutie korekčného vektora. Použite metódu "
"<i>Presun hviezdy a výpočet chyby</i> na odhad zostávajúcej chyby.</p>"

#: ekos/align/polaralignmentassistant.cpp:1313
#, kde-format
msgid ""
"<p>Adjust mount's <i>Altitude and Azimuth knobs</i> to reduce the polar "
"alignment error.</p><p>Be patient, plate solving can be affected by knob "
"movement. Consider using results after 2 images.  Click <i>Stop</i> when "
"you're finished.</p>"
msgstr ""
"<p>Nastavte <i>gombíky výšky a azimutu</i> montáže na zníženie chyby "
"polárneho zarovnania.</p><p>Buďte trpezlivý, riešenie platničky môže byť "
"ovplyvnené pohybom gombíka. Zvážte použitie výsledkov po 2 snímkach. "
"Kliknite na <i>Zastaviť</i> keď ste hotový.</p>"

#: ekos/align/polaralignmentassistant.cpp:1315
#, kde-format
msgid ""
"<p>Adjust mount's <i>Altitude knob</i> to move the star along the yellow "
"line, then adjust the <i>Azimuth knob</i> to move it along the Green line "
"until the selected star is centered within the crosshair.</p><p>Click "
"<i>Stop</i> when the star is centered.</p>"
msgstr ""
"<p>Nastavte <i>gombík výšky</i> montáže na pohyb hviezdy pozdĺž žltej čiary, "
"potom nastavte <i>gombík azimutu</i> na pohyb pozdĺž zelenej čiary, kým "
"vybraná hviezda nie je vycentrovaná v kríži.</p><p>Kliknite na <i>Zastaviť</"
"i> keď je hviezda vycentrovaná.</p>"

#: ekos/align/polaralignmentassistant.cpp:1331
#, kde-format
msgid "Cannot change to MoveStar algorithm once refresh has begun"
msgstr "Nie je možné prepnúť na algoritmus MoveStar po začatí obnovy"

#: ekos/align/polaralignmentassistant.cpp:1365
#, kde-format
msgid "PAC: Polar Alignment Corrector connected."
msgstr "PAC: Korektor polárneho zarovnania pripojený."

#: ekos/align/polaralignmentassistant.cpp:1378
#, kde-format
msgid "PAC: Correction in progress – adjusting azimuth and altitude axes..."
msgstr "PAC: Korekcia prebieha – nastavuje sa azimut a výška..."

#: ekos/align/polaralignmentassistant.cpp:1383
#, kde-format
msgid "PAC: Correction applied. Capturing next image to verify alignment..."
msgstr ""
"PAC: Korekcia aplikovaná. Sníma sa ďalšia snímka na overenie zarovnania..."

#: ekos/align/polaralignmentassistant.cpp:1389
#, kde-format
msgid "PAC: Correction failed. Stopping polar alignment."
msgstr "Spracovanie riešenie pre polárne vyrovnanie..."

#: ekos/align/polaralignmentassistant.cpp:1420
#, kde-format
msgid ""
"PAC: Polar alignment successful! Total error %1' is within threshold %2'."
msgstr ""
"PAC: Polárne zarovnanie úspešné! Celková chyba %1' je v rámci prahu %2'."

#: ekos/align/polaralignmentassistant.cpp:1431
#, kde-format
msgid "PAC: Correction timeout (%1s) reached. Total error is %2'. Stopping."
msgstr ""
"PAC: Časový limit korekcie (%1s) dosiahnutý. Celková chyba je %2'. "
"Zastavujem."

#: ekos/align/polaralignmentassistant.cpp:1461
#, kde-format
msgid "PAC: Az error increase confirmed (%1' → %2') – reversing Az direction."
msgstr "PAC: Zvýšenie chyby Az potvrdené (%1' → %2') – obracanie smeru Az."

#: ekos/align/polaralignmentassistant.cpp:1467
#, kde-format
msgid ""
"PAC: Az error increase not confirmed (likely noise) – keeping original "
"direction."
msgstr ""
"PAC: Zvýšenie chyby Az nepotvrdené (pravdepodobne šum) – ponechávam pôvodný "
"smer."

#: ekos/align/polaralignmentassistant.cpp:1474
#, kde-format
msgid ""
"PAC: Alt error increase confirmed (%1' → %2') – reversing Alt direction."
msgstr "PAC: Zvýšenie chyby Alt potvrdené (%1' → %2') – obracanie smeru Alt."

#: ekos/align/polaralignmentassistant.cpp:1480
#, kde-format
msgid ""
"PAC: Alt error increase not confirmed (likely noise) – keeping original "
"direction."
msgstr ""
"PAC: Zvýšenie chyby Alt nepotvrdené (pravdepodobne šum) – ponechávam pôvodný "
"smer."

#: ekos/align/polaralignmentassistant.cpp:1505
#, kde-format
msgid ""
"PAC: No improvement for %1 consecutive iteration(s) (best: %2', current: "
"%3')."
msgstr ""
"PAC: Žiadne zlepšenie pre %1 po sebe idúcich iterácií (najlepšie: %2', "
"aktuálne: %3')."

#: ekos/align/polaralignmentassistant.cpp:1511
#, kde-format
msgid ""
"PAC: No improvement after %1 consecutive iterations. Best error reached: "
"%2'. Stopping polar alignment."
msgstr ""
"PAC: Žiadne zlepšenie po %1 po sebe idúcich iteráciách. Najlepšia dosiahnutá "
"chyba: %2'. Zastavujem polárne zarovnanie."

#: ekos/align/polaralignmentassistant.cpp:1528
#, kde-format
msgid ""
"PAC: Az error increased (%1' → %2') – re-solving to confirm before direction "
"change."
msgstr ""
"PAC: Chyba Az sa zvýšila (%1' → %2') – znovu riešenie na potvrdenie pred "
"zmenou smeru."

#: ekos/align/polaralignmentassistant.cpp:1535
#, kde-format
msgid ""
"PAC: Alt error increased (%1' → %2') – re-solving to confirm before "
"direction change."
msgstr ""
"PAC: Chyba Alt sa zvýšila (%1' → %2') – znovu riešenie na potvrdenie pred "
"zmenou smeru."

#: ekos/align/polaralignmentassistant.cpp:1559
#, kde-format
msgid "PAC: Commanding corrector – Az: %1'  Alt: %2'  Total: %3'"
msgstr "PAC: Riadi korektor – Az: %1'  Alt: %2'  Celkovo: %3'"

#. i18n: ectx: property (toolTip), widget (QStackedWidget, PAHWidgets)
#: ekos/align/polaralignmentassistant.ui:44
#, kde-format
msgid ""
"<p>Polar Alignment Helper tool requires the following:</p><p>1. German "
"Equatorial Mount</p><p>2. Wide FOV &gt; 1 degrees</p><p>For small FOVs, use "
"the Legacy Polar Alignment Tool.</p>"
msgstr ""
"<p>Nástroj pomocníka polárneho zarovnania vyžaduje nasledujúce:</p><p>1. "
"Nemecká ekvatoriálna montáž</p><p>2. Široké zorné pole &gt; 1 stupeň</"
"p><p>Pre malé zorné polia použite starší nástroj polárneho zarovnania.</p>"

#. i18n: ectx: property (text), widget (QLabel, introText)
#: ekos/align/polaralignmentassistant.ui:78
#, kde-format
msgid ""
"<html><head/><body><p>Put your equatorial mount either (a) in the home "
"position pointed toward the celestial pole or (b) pointed anywhere ideally "
"near the meridian. Select <span style=\" font-weight:600;\">mount direction</"
"span> and <span style=\" font-weight:600;\">speed </span>and then click "
"<span style=\" font-weight:600;\">Start</span> to begin the polar alignment "
"process.</p></body></html>"
msgstr ""
"<html><head/><body><p>Umiestnite vašu ekvatoriálnu montáž buď (a) v domácej "
"polohe smerujúcej k nebeskému pólu alebo (b) kdekoľvek, ideálne blízko "
