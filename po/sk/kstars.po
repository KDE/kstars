#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_LimitedResourcesMode)
#: fitsviewer/opsfits.ui:371
#, kde-format
msgid ""
"<html><head/><body><p>Enable limited resource mode to turn off any resource-"
"intensive operations:</p><ul style=\"margin-top: 0px; margin-bottom: 0px; "
"margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;\"><li style=\" "
"margin-top:12px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-"
"block-indent:0; text-indent:0px;\"><span style=\" font-weight:600;\">Auto "
"debayer</span>: Bayered images will not be debayered. Only grayscale images "
"are shown.</li><li style=\" margin-top:0px; margin-bottom:0px; margin-"
"left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;\"><span "
"style=\" font-weight:600;\">Auto WCS</span>: World Coordinate System data "
"will not be processed. WCS maps sky coordinates to image coordinates. "
"Equatorial grid lines, object identification, and telescope slew within an "
"image are disabled.</li><li style=\" margin-top:0px; margin-bottom:12px; "
"margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;"
"\"><span style=\" font-weight:600;\">3D Cube</span>: RGB images will not be "
"processed. Only grayscale images are shown.</li></ul></body></html>"
msgstr ""
"<html><head/><body><p>Povoliť režim obmedzených zdrojov pre vypnutie "
"akýchkoľvek operácií náročných na zdroje:</p><ul style=\"margin-top: 0px; "
"margin-bottom: 0px; margin-left: 0px; margin-right: 0px; -qt-list-indent: 1;"
"\"><li style=\" margin-top:12px; margin-bottom:0px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0; text-indent:0px;\"><span style=\" font-"
"weight:600;\">Auto debayerovanie</span>: Bayerované snímky sa nebudú "
"debayerovať. Zobrazujú sa len šedotónové snímky.</li><li style=\" margin-"
"top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-"
"indent:0; text-indent:0px;\"><span style=\" font-weight:600;\">Auto WCS</"
"span>: Dáta Svetového súradnicového systému sa nebudú spracovávať. WCS "
"mapuje nebeské súradnice na súradnice snímky. Ekvatoriálne čiary mriežky, "
"identifikácia objektov a nasmerovania ďalekohľadu v snímke sú zakázané.</"
"li><li style=\" margin-top:0px; margin-bottom:12px; margin-left:0px; margin-"
"right:0px; -qt-block-indent:0; text-indent:0px;\"><span style=\" font-"
"weight:600;\">3D kocka</span>: RGB snímky sa nebudú spracovávať. Zobrazujú "
"sa len šedotónové snímky.</li></ul></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_LimitedResourcesMode)
#: fitsviewer/opsfits.ui:374
#, kde-format
msgid "Limited resources mode"
msgstr "Režim obmedzených zdrojov"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_AutoDebayer)
#: fitsviewer/opsfits.ui:381
#, kde-format
msgid "Automatically debayer captured image if it contains a bayer pattern"
msgstr "Automaticky debayerovať nasnímané snímky, ak obsahujú Bayerov vzor"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_AutoDebayer)
#: fitsviewer/opsfits.ui:384
#, kde-format
msgid "Auto debayer"
msgstr "Auto debayerovanie"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_AutoWCS)
#: fitsviewer/opsfits.ui:394
#, kde-format
msgid ""
"<html><head/><body><p>Automatically load World-Coordinate-System (WCS) data "
"when opening a FITS file.</p><p><span style=\" font-weight:600;\">Warning: "
"Only enable this option on very fast machines as it can lead to "
"unpredictable behavior resulting in crashes on slower machines.</span></p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Automaticky načítať dáta Svetového súradnicového "
"systému (WCS) pri otvorení súboru FITS.</p><p><span style=\" font-weight:600;"
"\">Upozornenie: Povoľte túto možnosť len na veľmi rýchlych počítačoch, "
"pretože môže viesť k nepredvídateľnému správaniu a pádoch na pomalších "
"počítačoch.</span></p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_AutoWCS)
#: fitsviewer/opsfits.ui:397
#, kde-format
msgid "Auto WCS"
msgstr "Auto WCS"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_Auto3DCube)
#: fitsviewer/opsfits.ui:404
#, kde-format
msgid ""
"<html><head/><body><p>Process 3D (RGB) FITS images. If unchecked, only first "
"channel is processed.</p><p>NOTE: Live Stacker will always display a color "
"image if requested to do so.</p></body></html>"
msgstr ""
"<html><head/><body><p>Spracovať 3D (RGB) snímky FITS. Ak je odškrtnuté, "
"spracuje sa len prvý kanál.</p><p>POZNÁMKA: Live Stacker vždy zobrazí "
"farebnú snímku, ak je o to požiadaný.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_Auto3DCube)
#: fitsviewer/opsfits.ui:407
#, kde-format
msgid "3D cube"
msgstr "3D kocka"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_NonLinearHistogram)
#: fitsviewer/opsfits.ui:417
#, kde-format
msgid ""
"<html><head/><body><p>Display histogram for the stretched non-linear image.</"
"p></body></html>"
msgstr ""
"<html><head/><body><p>Zobraziť histogram pre roztiahnutú nelineárnu snímku.</"
"p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_NonLinearHistogram)
#: fitsviewer/opsfits.ui:420
#, kde-format
msgid "Non linear histogram"
msgstr "Nelineárny histogram"

#. i18n: ectx: property (toolTip), widget (QLabel, label_3)
#: fitsviewer/opsfits.ui:429
#, kde-format
msgid ""
"<html><head/><body><p>Select a catalog to use to identify objects in the "
"image. The default is the internal Sky Map. External catalogs require WCS "
"and internet access.</p><p><span style=\" font-weight:600;\">Warning: "
"Querying external catalogs can be slow on slow machines.</span></p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Vyberte katalóg na identifikáciu objektov v snímke. "
"Predvolená je interná mapa oblohy. Externé katalógy vyžadujú WCS a "
"internetový prístup.</p><p><span style=\" font-weight:600;\">Upozornenie: "
"Dotazovanie externých katalógov môže byť pomalé na pomalých počítačoch.</"
"span></p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_3)
#: fitsviewer/opsfits.ui:432
#, kde-format
msgid "Object Catalog:"
msgstr "Katalóg objektov:"

