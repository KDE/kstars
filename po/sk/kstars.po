msgstr "Zobrazovať impulzy RA na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeDECp), group (Analyze)
#: kstars.kcfg:3667
#, kde-format
msgid "Display DEC Pulses on the Analyze Statistics Plot."
msgstr "Zobrazovať impulzy DEC na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeDrift), group (Analyze)
#: kstars.kcfg:3671
#, kde-format
msgid "Display Drift on the Analyze Statistics Plot."
msgstr "Zobrazovať drift na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeRMS), group (Analyze)
#: kstars.kcfg:3675
#, kde-format
msgid "Display RMS Error on the Analyze Statistics Plot."
msgstr "Zobrazovať chybu RMS na grafe štatistík Analyze."

