msgstr "  Winsor strih: "

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, Alpha)
#. i18n: ectx: property (toolTip), widget (QLabel, AlphaLabel)
#: fitsviewer/livestacking.ui:1422 fitsviewer/livestacking.ui:1643
#, kde-format
msgid ""
"<html><head/><body><p>Relaxation / damping between iterations. 1.0 = no "
"damping, &lt;1.0 = smoother (but slower convergence).</p><p>Usual values 0.7 "
"- 0.9</p></body></html>"
msgstr ""
"<html><head/><body><p>Relaxácia / tlmenie medzi iteráciami. 1,0 = žiadne "
"tlmenie, &lt;1,0 = hladší (ale pomalšia konvergencia).</p><p>Obvyklé hodnoty "
"0,7 - 0,9</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, HighSigma)
#. i18n: ectx: property (toolTip), widget (QLabel, HighSigmaLabel)
#: fitsviewer/livestacking.ui:1515 fitsviewer/livestacking.ui:1618
#, kde-format
msgid ""
"<html><head/><body><p>Value of High Sigma to be used in pixel rejection.</"
"p></body></html>"
msgstr ""
"<html><head/><body><p>Hodnota vysokej sigmy na použitie pri odmietnutí "
"pixelov.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, HighSigmaLabel)
#: fitsviewer/livestacking.ui:1621
#, kde-format
msgid "High Sigma:"
msgstr "Vysoká sigma:"

#. i18n: ectx: property (text), widget (QLabel, AlphaLabel)
#: fitsviewer/livestacking.ui:1646
#, kde-format
msgid "Alpha:"
msgstr "Alfa:"

#. i18n: ectx: property (toolTip), widget (QLabel, NormalizationLabel)
#. i18n: ectx: property (toolTip), widget (QComboBox, Normalization)
#: fitsviewer/livestacking.ui:1668 fitsviewer/livestacking.ui:1693
#, kde-format
msgid ""
"<html><head/><body><p>Normalize images before stacking:</p><p>- None. No "
"normalization.</p><p>- Linear. Normalize each sub to the brightness of the "
"alignment master prior to stacking. In addition, the image edges are "
"normalized to maintain appropriate brightness.</p></body></html>"
msgstr ""
"<html><head/><body><p>Normalizovať snímky pred skládaním:</p><p>- Žiadna. "
"Žiadna normalizácia.</p><p>- Lineárna. Normalizovať každý záber na jas "
"masterovej snímky zarovnávania pred skládaním. Okrem toho sa normalizujú "
"okraje snímky pre zachovanie vhodného jasu.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, NormalizationLabel)
#: fitsviewer/livestacking.ui:1671
#, kde-format
msgid "Normalization:"
msgstr "Normalizácia:"

#. i18n: ectx: property (toolTip), widget (QLabel, StackingMinimized)
