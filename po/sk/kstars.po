msgstr "uhlové sekundy"

#. i18n: ectx: property (text), widget (QLabel, label_39)
#: ekos/focus/opsfocussettings.ui:90
#, kde-format
msgid "Display Units:"
msgstr "Jednotky zobrazenia:"

#. i18n: ectx: property (toolTip), widget (QCheckBox, focusAutoStarEnabled)
#: ekos/focus/opsfocussettings.ui:109
#, kde-format
msgid ""
"<html><head/><body><p>This option is only active when Sub Frame is "
"selected.  Check to allow Ekos to select a single star for focus; uncheck to "
"allow the user to select the star to use in FitsViewer.</p></body></html>"
msgstr ""
"<html><head/><body><p>Táto možnosť je aktívna len pri výbere Podzáberu. "
"Zaškrtnite pre povolenie Ekos vybrať jednu hviezdu pre zaostrovanie; "
"odškrtnite pre povolenie používateľovi vybrať hviezdu v FitsViewer.</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, focusAutoStarEnabled)
#: ekos/focus/opsfocussettings.ui:112
#, kde-format
msgid "Auto Select Star"
msgstr "Automatický výber hviezdy"

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, focusGuideSettleTime)
#: ekos/focus/opsfocussettings.ui:128
#, kde-format
msgid ""
"<html><head/><body><p>Wait this many seconds after autofocus completes "
"before resuming guiding.</p></body></html>"
msgstr ""
"<html><head/><body><p>Vynútiť hodnotu teploty pred zachytením obrázku</p></"
"body></html>"

#. i18n: ectx: property (toolTip), widget (QRadioButton, focusSubFrame)
#: ekos/focus/opsfocussettings.ui:147
#, kde-format
msgid ""
"<html><head/><body><p>Select Sub Frame to make focus to use a single star "
"(note: Full Field uses multiple stars).  In this mode the Auto Select Star "
"checkbox becomes active to allow either Ekos to select a star (when checked) "
"or to allow the user to manually select the star in FitsViewer (when "
"unchecked).</p></body></html>"
msgstr ""
"<html><head/><body><p>Vyberte Podzáber pre zaostrovanie pomocou jednej "
"hviezdy (poznámka: Celé pole používa viacero hviezd). V tomto režime sa "
"zaškrtávacie políčko Automatický výber hviezdy stane aktívnym pre povolenie "
"buď Ekos vybrať hviezdu (ak je zaškrtnuté) alebo povolenie používateľovi "
"manuálne vybrať hviezdu vo FitsViewer (ak je odškrtnuté).</p></body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, focusSubFrame)
#: ekos/focus/opsfocussettings.ui:150
#, kde-format
msgid "Sub Frame"
msgstr "Rám"

#. i18n: ectx: property (text), widget (QCheckBox, useFocusDarkFrame)
#: ekos/focus/opsfocussettings.ui:169
#, kde-format
