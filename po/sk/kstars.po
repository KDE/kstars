#. i18n: ectx: property (toolTip), widget (QComboBox, kcfg_SolverType)
#: ekos/align/opsalign.ui:94
#, kde-format
msgid ""
"<html><head/><body><p align=\"center\">Selects the method of plate solving "
"with the StellarSolver Library</p><ul><li>'Internal SEP' option uses "
"StellarSolver's internal build of Astrometry.net and requires no external "
"programs. </li><li>'Local Astrometry' uses a local installation of command "
"line astrometry.net on Linux and Mac or ANSVR on Windows. </li><li>'Local "
"ASTAP' uses a local installation of the ASTAP program. </li><li>'Local "
"Watney' uses a local installation of the Watney Astrometry Solver Program.</"
"li><li>'Online' uses either astrometry.net over the internet or ANSVR on a "
"nearby computer. <span style=\" font-weight:600;\">Note</span>: If bandwidth "
"is a concern, consider using 'Internal SEP' instead of 'Builtin Method of "
"Solver'.</li></ul></body></html>"
msgstr ""
"<html><head/><body><p align=\"center\">Výber metódy riešenia platničiek "
"pomocou knižnice StellarSolver</p><ul><li>Možnosť 'Interný SEP' používa "
"interné zostavenie Astrometry.net od StellarSolver a nevyžaduje žiadne "
"externé programy. </li><li>'Lokálna astrometria' používa lokálnu inštaláciu "
"príkazového riadku astrometry.net na Linuxe a Mac alebo ANSVR na Windows. </"
"li><li>'Lokálny ASTAP' používa lokálnu inštaláciu programu ASTAP. </"
"li><li>'Lokálny Watney' používa lokálnu inštaláciu programu Watney "
"Astrometry Solver.</li><li>'Online' používa buď astrometry.net cez internet "
"alebo ANSVR na blízkom počítači. <span style=\" font-weight:600;\">Poznámka</"
"span>: Ak je šírka pásma problémom, zvážte použitie 'Interný SEP' namiesto "
"'Vstavanej metódy riešiteľa'.</li></ul></body></html>"

