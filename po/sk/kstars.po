"<html><head/><body><p>Počet iterácií. Udržujte nízky pre minimalizáciu réžie "
"spracovania.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, IterationsLabel)
#: fitsviewer/livestacking.ui:1387
#, kde-format
msgid "Iterations:"
msgstr "Iterácie:"

#. i18n: ectx: property (toolTip), widget (QLabel, WinsorCutoffLabel)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, WinsorCutoff)
#: fitsviewer/livestacking.ui:1409 fitsviewer/livestacking.ui:1593
#, kde-format
msgid ""
"<html><head/><body><p>Winsorization cutoff in units of sigma to be used in "
"pixel rejection.</p></body></html>"
msgstr ""
"<html><head/><body><p>Winzorizačný strih v jednotkách sigmy na použitie pri "
"odmietnutí pixelov.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, WinsorCutoffLabel)
#: fitsviewer/livestacking.ui:1412
#, kde-format
