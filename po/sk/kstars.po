#. i18n: ectx: property (toolTip), widget (QGroupBox, StackingGroupBox)
#: fitsviewer/livestacking.ui:983
#, kde-format
msgid ""
"<html><head/><body><p>The maximum number of subs held in memory whilst "
"processing. The larger the value, the better the quality of the stacking "
"process, but at the cost of more processing time and memory used.</p><p><br/"
"></p><p>Processes such as sigma clipping will use this many subs to "
"calculate statistics to use on all subs.</p></body></html>"
msgstr ""
"<html><head/><body><p>Maximálny počet záberov uchovávaných v pamäti počas "
"spracovania. Čím väčšia hodnota, tým lepšia kvalita procesu skládania, ale "
"za cenu väčšieho času spracovania a použitej pamäte.</p><p><br/></"
"p><p>Procesy ako sigma rezanie použijú toľko záberov na výpočet štatistík "
"pre použitie na všetkých záberoch.</p></body></html>"

#. i18n: ectx: property (title), widget (QGroupBox, StackingGroupBox)
#. i18n: ectx: property (text), widget (QLabel, StackingMinimized)
#: fitsviewer/livestacking.ui:986 fitsviewer/livestacking.ui:1716
#, kde-format
msgid "Stacking"
msgstr "Skladanie"

#. i18n: ectx: property (toolTip), widget (QLabel, KappaLabel)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, Kappa)
#: fitsviewer/livestacking.ui:1022 fitsviewer/livestacking.ui:1481
#, kde-format
msgid ""
"<html><head/><body><p>Kappa clamps the pixel update in the range 1/kappa to "
"kappa versus the original value. So 1 means no change, the higher kappa the "
"larger the possible updates.</p><p>Usual values are in the range 1.5 to 2.0. "
"Reduce if images appear over processed, e.g. star ringing.</p></body></html>"
msgstr ""
"<html><head/><body><p>Kappa obmedzuje aktualizáciu pixelov v rozsahu 1/kappa "
"až kappa oproti pôvodnej hodnote. Takže 1 znamená žiadnu zmenu, čím vyššia "
"kappa, tým väčšie možné aktualizácie.</p><p>Obvyklé hodnoty sú v rozsahu 1,5 "
"až 2,0. Znížte, ak sa snímky javia ako preagresívne spracované, napr. kruhy "
"okolo hviezd.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, KappaLabel)
#: fitsviewer/livestacking.ui:1025
#, kde-format
msgid "  Kappa:"
msgstr "  Kappa:"

#. i18n: ectx: property (toolTip), widget (QLabel, InMemoryLabel)
#. i18n: ectx: property (toolTip), widget (QSpinBox, NumInMem)
#: fitsviewer/livestacking.ui:1047 fitsviewer/livestacking.ui:1453
#, kde-format
msgid ""
"<html><head/><body><p>The maximum number of subs held in memory whilst "
"processing. The larger the value, the better the quality of the stacking "
"process, but at the cost of more processing time and memory used.</"
"p><p>Processes such as sigma clipping will use this many subs to calculate "
"statistics to use on all subs.</p></body></html>"
msgstr ""
"<html><head/><body><p>Maximálny počet záberov uchovávaných v pamäti počas "
"spracovania. Čím väčšia hodnota, tým lepšia kvalita procesu skládania, ale "
"za cenu väčšieho času spracovania a použitej pamäte.</p><p>Procesy ako sigma "
"rezanie použijú toľko záberov na výpočet štatistík pre použitie na všetkých "
"záberoch.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, InMemoryLabel)
#: fitsviewer/livestacking.ui:1050
#, kde-format
msgid "In Memory Subs:"
msgstr "Podsnímky v pamäti:"

#. i18n: ectx: property (toolTip), widget (QComboBox, Weighting)
#. i18n: ectx: property (toolTip), widget (QLabel, WeightingLabel)
#: fitsviewer/livestacking.ui:1072 fitsviewer/livestacking.ui:1268
#, kde-format
msgid ""
"<html><head/><body><p>Frame weighting:</p><p>- Equal. All frames have the "
"same weight.</p><p>- HFR. Frames are weighted by 1 / Average HFR.</p><p>- "
"Num Stars. Frames are weighted by the number of stars detected in the frame."
"</p></body></html>"
msgstr ""
"<html><head/><body><p>Váhovanie rámcov:</p><p>- Rovnaké. Všetky rámce majú "
"rovnakú váhu.</p><p>- HFR. Rámce sú vážené podľa 1 / Priemerné HFR.</p><p>- "
"Počet hviezd. Rámce sú vážené podľa počtu hviezd detekovaných v rámci.</p></"
"body></html>"

#. i18n: ectx: property (text), item, widget (QComboBox, Weighting)
#: fitsviewer/livestacking.ui:1076
#, kde-format
msgid "Equal"
msgstr "Rovnaký"

#. i18n: ectx: property (toolTip), widget (QLabel, DownscaleLabel)
#. i18n: ectx: property (toolTip), widget (QComboBox, LSDownscale)
#: fitsviewer/livestacking.ui:1106 fitsviewer/livestacking.ui:1201
#, kde-format
msgid ""
"<html><head/><body><p>Downscale images:</p><p>- None. No downscaling "
"applied .</p><p>- 2x2. Subs and masters are downscaled 2x2.</p><p>- 3x3. "
"Subs and masters are downscaled 3x3.</p><p>- 4x4. Subs and masters are "
"downscaled 4x4.</p></body></html>"
msgstr ""
"<html><head/><body><p>Zmenšenie snímok:</p><p>- Žiadne. Žiadne zmenšenie sa "
"neaplikuje.</p><p>- 2x2. Záberové snímky a masterové snímky sú zmenšené 2x2."
"</p><p>- 3x3. Záberové snímky a masterové snímky sú zmenšené 3x3.</p><p>- "
"4x4. Záberové snímky a masterové snímky sú zmenšené 4x4.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, DownscaleLabel)
#: fitsviewer/livestacking.ui:1109
#, kde-format
msgid "  Downscale: "
msgstr "  Zmenšenie: "

#. i18n: ectx: property (toolTip), widget (QComboBox, StackingMethod)
#: fitsviewer/livestacking.ui:1131
#, kde-format
msgid ""
"<html><head/><body><p>Stacking method:</p><p>- Average. Uses a simple mean "
"average. No pixel rejection is applied.</p><p>- Sigma Clipping. Outlying "
"pixels are rejected.</p><p>- Winsorized Sigma Clipping. Winsorized version "
"of sigma clipping</p><p>- ImageMM. Implements ImageMM stacking as per "
"https://iopscience.iop.org/article/10.3847/1538-3881/adfb72 NOTE: this "
"method is very resource intensive</p></body></html>"
msgstr ""
"<html><head/><body><p>Metóda skládania:</p><p>- Priemer. Používa jednoduchý "
"aritmetický priemer. Nevykonáva sa odmietnutie pixelov.</p><p>- Sigma "
"rezanie. Odľahlé pixely sa odmietajú.</p><p>- Winzorované sigma rezanie. "
"Winzorovaná verzia sigma rezania.</p><p>- ImageMM. Implementuje skládanie "
"ImageMM podľa https://iopscience.iop.org/article/10.3847/1538-3881/adfb72 "
"POZNÁMKA: táto metóda je veľmi náročná na zdroje</p></body></html>"

#. i18n: ectx: property (text), item, widget (QComboBox, StackingMethod)
#: fitsviewer/livestacking.ui:1146
#, kde-format
msgid "Sigma Clipping"
msgstr "Sigma orezanie"

#. i18n: ectx: property (text), item, widget (QComboBox, StackingMethod)
#: fitsviewer/livestacking.ui:1151
#, kde-format
msgid "Winsorized SC"
msgstr "Winsorized SC"

#. i18n: ectx: property (text), item, widget (QComboBox, StackingMethod)
#: fitsviewer/livestacking.ui:1156
#, kde-format
msgid "ImageMM"
msgstr "ObrázokMM"

#. i18n: ectx: property (toolTip), widget (QLabel, PSFUpdateLabel)
#: fitsviewer/livestacking.ui:1176
#, kde-format
msgid ""
"<html><head/><body><p>Adapt PSF used in ImageMM algorithm.</p><p>0 = no PSF "
"Update</p><p>n = update PSF every n iterations</p><p><br/></p><p>Can cause "
"star ringing if applied too frequently.</p></body></html>"
msgstr ""
"<html><head/><body><p>Prispôsobiť PSF použitú v algoritme ImageMM.</p><p>0 = "
"žiadna aktualizácia PSF</p><p>n = aktualizovať PSF každých n iterácií</"
"p><p><br/></p><p>Môže spôsobovať kruhy okolo hviezd, ak sa aplikuje príliš "
"často.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, PSFUpdateLabel)
#: fitsviewer/livestacking.ui:1179
#, kde-format
msgid "PSF Update:"
msgstr "Aktualizácia PSF:"

#. i18n: ectx: property (text), item, widget (QComboBox, LSDownscale)
#: fitsviewer/livestacking.ui:1218
#, kde-format
msgid "3x3"
msgstr "3x3"

#. i18n: ectx: property (toolTip), widget (QLabel, StackingMethodLabel)
#: fitsviewer/livestacking.ui:1243
#, kde-format
msgid ""
"<html><head/><body><p>Pixel rejection algorithm:</p><p>- None. No rejection "
"is applied.</p><p>- Sigma Clipping. Outlying pixels are rejected.</p><p>- "
"Winsorized Sigma Clipping. Winsorized version of sigma clipping</p><p>- "
"ImageMM. Implements ImageMM stacking as per https://iopscience.iop.org/"
"article/10.3847/1538-3881/adfb72 NOTE: this method is very resource "
"intensive</p></body></html>"
msgstr ""
"<html><head/><body><p>Algoritmus odmietnutia pixelov:</p><p>- Žiadny. Žiadne "
"odmietnutie sa neaplikuje.</p><p>- Sigma rezanie. Odľahlé pixely sa "
"odmietajú.</p><p>- Winzorované sigma rezanie. Winzorovaná verzia sigma "
"rezania.</p><p>- ImageMM. Implementuje skládanie ImageMM podľa https://"
"iopscience.iop.org/article/10.3847/1538-3881/adfb72 POZNÁMKA: táto metóda je "
"veľmi náročná na zdroje</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, WeightingLabel)
#: fitsviewer/livestacking.ui:1271
#, kde-format
msgid "  Frame Weight: "
msgstr "  Váha snímky: "

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, Sigma)
#. i18n: ectx: property (toolTip), widget (QLabel, SigmaLabel)
#: fitsviewer/livestacking.ui:1281 fitsviewer/livestacking.ui:1340
#, kde-format
msgid ""
"<html><head/><body><p>Sigma Scale is the MAD multiplier to remove outliers "
"(usually in the range 0.6 - 0.9)</p></body></html>"
msgstr "<html><head/><body><p>Preemptívne hodiny vypnutia</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QLabel, LowSigmaLabel)
#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, LowSigma)
#: fitsviewer/livestacking.ui:1315 fitsviewer/livestacking.ui:1540
#, kde-format
msgid ""
"<html><head/><body><p>Value of Low Sigma to be used in pixel rejection.</p></"
