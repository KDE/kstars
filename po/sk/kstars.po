#: fitsviewer/bayerparameters.cpp:19
#, kde-format
msgctxt "@item:inlistbox Debayer engine"
msgid "DC1394"
msgstr "DC1394"

#: fitsviewer/bayerparameters.cpp:21
#, kde-format
msgctxt "@item:inlistbox Debayer engine"
msgid "OpenCV"
msgstr "Otvoriť"

#: fitsviewer/bayerparameters.cpp:25
#, kde-format
msgctxt "@item:inlistbox Debayer engine"
msgid "Unknown"
msgstr "Neznáme"

#: fitsviewer/bayerparameters.cpp:31
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<b>DC1394</b>: Uses the legacy libdc1394 debayer engine<br/>• Slower but "
"very reliable<br/><br/><b>OpenCV</b>: Experimental OpenCV-based debayer "
"engine<br/>• Faster than libdc1394<br/>• Better edge handling"
msgstr ""
"<b>DC1394</b>: Používa starší debayerovací engine libdc1394<br/>• Pomalší, "
"ale veľmi spoľahlivý<br/><br/><b>OpenCV</b>: Experimentálny debayerovací "
"engine založený na OpenCV<br/>• Rýchlejší ako libdc1394<br/>• Lepšie "
"spracovanie hrán"

#: fitsviewer/bayerparameters.cpp:45
#, kde-format
msgctxt "@item:inlistbox OpenCV debayer algorithm"
msgid "Bilinear"
msgstr "Bilineárne"

#: fitsviewer/bayerparameters.cpp:47
#, kde-format
msgctxt "@item:inlistbox OpenCV debayer algorithm"
msgid "VNG"
msgstr "VNG"

#: fitsviewer/bayerparameters.cpp:49
#, kde-format
msgctxt "@item:inlistbox OpenCV debayer algorithm"
msgid "Edge-Aware"
msgstr "Citlivé na hrany"

#: fitsviewer/bayerparameters.cpp:53
#, kde-format
msgctxt "@item:inlistbox OpenCV debayer algorithm"
msgid "Unknown"
msgstr "Neznáme"

#: fitsviewer/bayerparameters.cpp:59
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<b>Bilinear</b>: Simple bilinear interpolation<br/>• Very fast, soft "
"edges<br/><br/><b>VNG</b>: Variable Number of Gradients<br/>• Improved color "
"reconstruction<br/>• 8-bit images only<br/><br/><b>Edge-Aware</b>: Edge-"
"aware interpolation<br/>• High quality and very fast"
msgstr ""
"<b>Bilineárna</b>: Jednoduchá bilineárna interpolácia<br/>• Veľmi rýchla, "
"mäkké hrany<br/><br/><b>VNG</b>: Variabilný počet gradientov<br/>• Vylepšená "
"rekonštrukcia farieb<br/>• Len 8-bitové snímky<br/><br/><b>Citlivá na hrany</"
"b>: Interpolácia citlivá na hrany<br/>• Vysoká kvalita a veľmi rýchla"

#: fitsviewer/bayerparameters.cpp:74
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "Nearest"
msgstr "Najbližšie"

#: fitsviewer/bayerparameters.cpp:76
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "Simple"
msgstr "Jednoduchá"

#: fitsviewer/bayerparameters.cpp:78
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "Bilinear"
msgstr "Bilineárne"

#: fitsviewer/bayerparameters.cpp:80
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "HQ Linear"
msgstr "HQ lineárne"

#: fitsviewer/bayerparameters.cpp:82
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "Edge Sense"
msgstr "Edge Sense"

#: fitsviewer/bayerparameters.cpp:84
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "VNG"
msgstr "VNG"

#: fitsviewer/bayerparameters.cpp:88 fitsviewer/bayerparameters.cpp:201
#, kde-format
msgctxt "@item:inlistbox DC1394 debayer method"
msgid "Unknown"
msgstr "Neznáme"

#: fitsviewer/bayerparameters.cpp:94
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<b>Nearest</b>: Fastest method, lowest quality<br/><br/><b>Simple</b>: Basic "
"interpolation, slightly smoothed<br/><br/><b>Bilinear</b>: Good balance of "
"speed and quality<br/><br/><b>HQ Linear</b>: Higher quality, slower<br/><br/"
"><b>Edge Sense</b>: Preserves edges, high quality<br/><br/><b>VNG</b>: "
"Highest quality, slowest"
msgstr ""
"<b>Najbližší</b>: Najrýchlejšia metóda, najnižšia kvalita<br/><br/"
"><b>Jednoduchá</b>: Základná interpolácia, mierne vyhladzená<br/><br/"
"><b>Bilineárna</b>: Dobrá rovnováha rýchlosti a kvality<br/><br/><b>HQ "
"lineárna</b>: Vyššia kvalita, pomalšia<br/><br/><b>Edge Sense</b>: Zachováva "
"hrany, vysoká kvalita<br/><br/><b>VNG</b>: Najvyššia kvalita, najpomalšia"

