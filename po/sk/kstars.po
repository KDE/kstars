#. i18n: ectx: property (toolTip), widget (QLabel, remoteDriversLabel)
#: ekos/profileeditor.ui:595
#, kde-format
msgid ""
"<html><head/><body><p>Add remote INDI drivers to chain with the local INDI "
"server configured by this profile. Format this field as a comma-separated "
"list of quoted driver name, host name/address and optional port:</p><p><span "
"style=\" font-weight:600;\">&quot;ZWO ASI120MC&quot;@192.168.1.50:8000</"
"span><br/>Connect to the named camera on 192.168.1.50, port 8000.</"
"p><p><span style=\" font-weight:600;\">&quot;EQMod Mount&quot;@192.168.1.50</"
"span><br/>Connect to the named mount on 192.168.1.50, port 7624.</p><p><span "
"style=\" font-weight:600;\">@192.168.1.50:8000</span><br/>Connect to all "
"drivers found on 192.168.1.50, port 8000.</p><p><span style=\" font-"
"weight:600;\">@192.168.1.50</span><br/>Connect to all drivers found on "
"192.168.1.50, port 7624.</p><p>When omitted, host defaults to localhost and "
"port defaults to 7624.<br/>Remote INDI drivers must be already running for "
"the connection to succeed.</p></body></html>"
msgstr ""
"<html><head/><body><p>Pridajte vzdialené ovládače INDI do reťaze s lokálnym "
"serverom INDI nakonfigurovaným týmto profilom. Naformátujte toto pole ako "
"zoznam oddelený čiarkami s názvom ovládača v úvodzovkách, názvom/adresou "
"hostiteľa a voliteľným portom:</p><p><span style=\" font-weight:600;\">&quot;"
"ZWO ASI120MC&quot;@192.168.1.50:8000</span><br/>Pripojiť k pomenovanej "
"kamere na 192.168.1.50, port 8000.</p><p><span style=\" font-weight:600;"
"\">&quot;EQMod Mount&quot;@192.168.1.50</span><br/>Pripojiť k pomenovanej "
"montáži na 192.168.1.50, port 7624.</p><p><span style=\" font-weight:600;"
"\">@192.168.1.50:8000</span><br/>Pripojiť ku všetkým ovládačom nájdeným na "
"192.168.1.50, port 8000.</p><p><span style=\" font-weight:600;"
"\">@192.168.1.50</span><br/>Pripojiť ku všetkým ovládačom nájdeným na "
"192.168.1.50, port 7624.</p><p>Ak je vynechané, hostiteľ predvolene "
"localhost a port predvolene 7624.<br/>Vzdialené ovládače INDI musia byť pred "
"pripojením už spustené.</p></body></html>"

