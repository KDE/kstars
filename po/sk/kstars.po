"<html><head/><body><p>Hodnota nízkej sigmy na použitie pri odmietnutí "
"pixelov.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, LowSigmaLabel)
#: fitsviewer/livestacking.ui:1318
#, kde-format
msgid "Low Sigma:"
msgstr "Nízka sigma:"

#. i18n: ectx: property (text), widget (QLabel, SigmaLabel)
#: fitsviewer/livestacking.ui:1343
#, kde-format
msgid "  Sigma Scale:"
msgstr "  Stupnica sigma:"

#. i18n: ectx: property (toolTip), widget (QSpinBox, PSFUpdate)
#: fitsviewer/livestacking.ui:1362
#, kde-format
msgid ""
"<html><head/><body><p>Adapt PSF used in ImageMM algorithm.</p><p>0 = no PSF "
"Update</p><p>n = update PSF every n iterations</p><p><br/></p><p>Can cause "
"star ringing if applied too frequently.</p><p><br/></p></body></html>"
msgstr ""
"<html><head/><body><p>Prispôsobiť PSF použitú v algoritme ImageMM.</p><p>0 = "
"žiadna aktualizácia PSF</p><p>n = aktualizovať PSF každých n iterácií</"
"p><p><br/></p><p>Môže spôsobovať kruhy okolo hviezd, ak sa aplikuje príliš "
"často.</p><p><br/></p></body></html>"

#. i18n: ectx: property (toolTip), widget (QLabel, IterationsLabel)
#. i18n: ectx: property (toolTip), widget (QSpinBox, Iterations)
#: fitsviewer/livestacking.ui:1384 fitsviewer/livestacking.ui:1565
#, kde-format
msgid ""
"<html><head/><body><p>Number of iterations. Keep low to minimize processing "
