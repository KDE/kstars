#. i18n: ectx: whatsthis, entry (AnalyzeEccentricity), group (Analyze)
#: kstars.kcfg:3631
#, kde-format
msgid ""
"Display the median eccentricity for the stars in the capture on the Analyze "
"Statistics Plot."
msgstr ""
"Zobrazovať mediánovú excentricitu hviezd v snímaní na grafe štatistík "
"Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeTemperature), group (Analyze)
#: kstars.kcfg:3635
#, kde-format
msgid "Display the ambient temperature on the Analyze Statistics Plot."
msgstr "Zobrazovať teplotu okolia na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (FocusPosition), group (Analyze)
#: kstars.kcfg:3639
#, kde-format
msgid "Display the autofocus solution position."
msgstr "Zobrazovať polohu riešenia autofokusu."

#. i18n: ectx: whatsthis, entry (AnalyzeNumStars), group (Analyze)
#: kstars.kcfg:3643
#, kde-format
