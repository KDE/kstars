#: ekos/scheduler/opsalignmentsettings.ui:58 kstars.kcfg:3483
#, kde-format
msgid ""
"When calculating position after captures, compute it every Nth capture. Set "
"to 0 to disable."
msgstr ""
"Pri výpočte polohy po snímaní vypočítajte ju každé N-té snímanie. Nastavte "
"na 0 pre deaktiváciu."

#. i18n: ectx: property (text), widget (QLabel, label_6)
#: ekos/scheduler/opsalignmentsettings.ui:61
#, kde-format
msgid "Verify captured image position every:"
msgstr "Overovať polohu nasnímaného obrázka každých:"

#. i18n: ectx: property (text), widget (QLabel, label_10)
#. i18n: ectx: property (text), widget (QLabel, DefaultDSSImageSizeUnitLabel)
#. i18n: ectx: property (text), widget (QLabel, DSSPaddingUnitLabel)
#: ekos/scheduler/opsalignmentsettings.ui:75 options/opsadvanced.ui:163
#: options/opsadvanced.ui:205
#, kde-format
msgid "arcminutes"
msgstr "oblúkové minúty"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_ResetMountModelOnAlignFail)
#: ekos/scheduler/opsalignmentsettings.ui:89
#, kde-format
msgid "Reset mount model on alignment failure"
msgstr "Vynulovať model montáže pri zlyhaní zarovnania"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_RealignAfterCalibrationFailure)
#: ekos/scheduler/opsalignmentsettings.ui:96
#, kde-format
msgid ""
"<html><head/><body><p>If guiding calibration fails then restart alignment "
"process before proceeding to guiding recalibration process again. This can "
"help recenter the target object in the field of view if the calibration "
"process strayed too far off.</p></body></html>"
msgstr ""
"<html><head/><body><p>Ak kalibrácia vedenia zlyhá, reštartujte proces "
"zarovnávania pred ďalším pokračovaním v procese opätovnej kalibrácie "
"vedenia. To môže pomôcť znova vycentrovať cieľový objekt v zornom poli, ak "
"sa kalibračný proces príliš vzdialil.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_RealignAfterCalibrationFailure)
#: ekos/scheduler/opsalignmentsettings.ui:99
#, kde-format
msgid "Restart alignment on guiding calibration failure"
msgstr "Reštartovať zarovnávanie pri zlyhaní kalibrácie vedenia"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_ResetMountModelBeforeJob)
#: ekos/scheduler/opsalignmentsettings.ui:106
#, kde-format
msgid "Reset mount model before starting each job:"
msgstr "Vynulovať model montáže pred spustením každej úlohy:"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_ForceAlignmentBeforeJob)
#: ekos/scheduler/opsalignmentsettings.ui:113
#, kde-format
msgid ""
"If Align is enabled, scheduler would initiate a realignment procedure before "
"restarting any jobs even if guiding is active."
msgstr ""
"Ak je zarovnávanie povolené, plánovač iniciuje procedúru opätovného "
"zarovnávania pred reštartovaním akýchkoľvek úloh, aj keď je vedenie aktívne."

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_ForceAlignmentBeforeJob)
#: ekos/scheduler/opsalignmentsettings.ui:116
#, kde-format
msgid "Force re-alignment before re-starting jobs"
msgstr "Vynútiť opätovné zarovnanie pred reštartovaním úloh"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_RememberJobProgress)
#: ekos/scheduler/opsjobssettings.ui:38
#, kde-format
msgid ""
"<html><head/><body><p>When processing a scheduled job, resume the sequence "
"starting from the last image present in storage.</p></body></html>"
msgstr ""
"<html><head/><body><p>Pri spracovaní naplánovanej úlohy obnoví sekvenciu od "
"posledného obrázka uloženého v pamäti.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_RememberJobProgress)
#: ekos/scheduler/opsjobssettings.ui:41
#, kde-format
msgid "Remember job progress"
msgstr "Pamätať si stav úlohy"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_GreedyScheduling)
#: ekos/scheduler/opsjobssettings.ui:51
#, kde-format
msgid ""
"<html><head/><body><p>When checked the scheduler tries to run lower priority "
"jobs when no higher priority job can run. Recommended.</p></body></html>"
msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_GreedyScheduling)
#: ekos/scheduler/opsjobssettings.ui:54
#, kde-format
msgid "Use greedy scheduling"
msgstr "Použiť chamtivé plánovanie"

#. i18n: ectx: property (toolTip), widget (QLabel, dawnOffsetLabel)
#: ekos/scheduler/opsoffsetsettings.ui:35
#, kde-format
msgid ""
"<html><body><p>Offset astronomical dawn by this many hours. This positive or "
"negative value adjusts the twilight restriction.</p></body></html>"
msgstr ""
"<html><body><p>Posunúť astronomický svitania o toľto hodín. Táto kladná "
"alebo záporná hodnota upravuje obmedzenie súmraku.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, dawnOffsetLabel)
#: ekos/scheduler/opsoffsetsettings.ui:38
#, kde-format
msgid "Dawn offset:"
msgstr "Posun úsvitu:"

#. i18n: ectx: property (toolTip), widget (QLabel, leadTimeLabel)
#: ekos/scheduler/opsoffsetsettings.ui:58
#, kde-format
msgid ""
"<html><head/><body><p>Lead time is the minimum time in minutes between jobs. "
"The scheduler starts execution of a job before its scheduled startup time by "
"this lead time. Early execution is useful as focusing, alignment, and "
"guiding procedures may take prolonged periods to time to complete.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p>Uvádzací čas je minimálny čas v minútach medzi "
"úlohami. Plánovač spustí vykonávanie úlohy pred jej naplánovaným časom "
"spustenia o tento uvádzací čas. Skoré spustenie je užitočné pri zaostrení, "
"zarovnaní a procedúre navedenia, čo môže trvať dlhší čas na ukončenie.</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QLabel, leadTimeLabel)
#: ekos/scheduler/opsoffsetsettings.ui:61
#, kde-format
msgid "Lead time:"
msgstr "Úvodný čas:"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_PreemptiveShutdown)
#: ekos/scheduler/opsoffsetsettings.ui:68
#, kde-format
msgid ""
"<html><head/><body><p>In case no scheduler job is scheduled for this many "
"hours, perform a complete shutdown procedure and restart observatory "
"operations once the next job is ready.</p></body></html>"
msgstr ""
"<html><head/><body><p>V prípade, že žiadna úloha plánovača nie je "
"naplánovaná tento počet hodín, vykonať kompletné vypnutie a reštartovať "
"observatórium, keď je pripravená ďalšia úloha.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_PreemptiveShutdown)
#: ekos/scheduler/opsoffsetsettings.ui:71
#, kde-format
msgid "Pre-emptive shutdown:"
msgstr "Preemptívne vypnutie:"

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, kcfg_PreemptiveShutdownTime)
#: ekos/scheduler/opsoffsetsettings.ui:81
#, kde-format
msgid "<html><head/><body><p>Pre-emptive shutdown hours</p></body></html>"
msgstr "<html><head/><body><p>Preemptívne hodiny vypnutia</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QLabel, preDawnLabel)
#: ekos/scheduler/opsoffsetsettings.ui:88
#, kde-format
msgid ""
"<html><head/><body><p>Do not permit jobs to be scheduled or executed past "
"this many minutes before dawn.</p></body></html>"
msgstr ""
"<html><head/><body><p>Nepovoliť plánovanie alebo spúšťanie úloh po tomto "
"počte minút pred úsvitom.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, preDawnLabel)
#: ekos/scheduler/opsoffsetsettings.ui:91
#, kde-format
msgid "Pre-dawn:"
msgstr "Pred úsvitom:"

#. i18n: ectx: property (toolTip), widget (QLabel, duskOffsetLabel)
#: ekos/scheduler/opsoffsetsettings.ui:127
#, kde-format
msgid ""
"<html><body><p>Offset astronomical dusk by this many hours. This positive or "
"negative value adjusts the twilight restriction.</p></body></html>"
msgstr ""
"<html><body><p>Posunúť astronomický súmrak o toľto hodín. Táto kladná alebo "
"záporná hodnota upravuje obmedzenie súmraku.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, duskOffsetLabel)
#: ekos/scheduler/opsoffsetsettings.ui:130
#, kde-format
msgid "Dusk offset:"
msgstr "Posun súmraku:"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_StopEkosAfterShutdown)
#: ekos/scheduler/opsscriptssettings.ui:38
#, kde-format
msgid "After shutdown procedure is successfully executed, stop INDI and Ekos."
msgstr "Po úspešnom vykonaní procedúry vypnutia zastavte INDI a Ekos."

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_StopEkosAfterShutdown)
#: ekos/scheduler/opsscriptssettings.ui:41
#, kde-format
msgid "Stop Ekos after shutdown"
msgstr "Zastaviť Ekos po vypnutí"

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_ShutdownScriptTerminatesINDI)
#: ekos/scheduler/opsscriptssettings.ui:48
#, kde-format
msgid ""
"<html><head/><body><p>If the shutdown script terminates INDI server, enable "
"this option so that no disconnection errors are generated.</p></body></html>"
msgstr ""
"<html><head/><body><p>Poveternostné podmienky musia ostať bezpečné. Keď sú "
"poveternostné podmienky nebezpečné, spustí sa procedúra vypnutia.</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_ShutdownScriptTerminatesINDI)
#: ekos/scheduler/opsscriptssettings.ui:51
#, kde-format
msgid "Shutdown script terminates INDI"
msgstr "Procedúra ukončenia zastavená."

#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_SchedulerWeather)
#: ekos/scheduler/opsweathersettings.ui:43
#, kde-format
msgid ""
"<html><head/><body><p><span style=\" font-weight:700;\">Enable Weather-Based "
"Scheduling:</span> Prevents new jobs from starting during weather warnings "
"or alerts. Existing jobs continue during warnings, but are aborted during "
"alerts. System initiates a soft shutdown and waits for improved conditions "
"or grace period expiration, after which the current job is terminated.</p></"
"body></html>"
msgstr ""
"<html><head/><body><p><span style=\" font-weight:700;\">Povoliť plánovanie "
"podľa počasia:</span> Zabraňuje spúšťaniu nových úloh počas meteorologických "
"varovaní alebo upozornení. Existujúce úlohy pokračujú počas varovaní, ale sú "
"prerušené počas upozornení. Systém iniciuje mäkké vypnutie a čaká na "
"zlepšenie podmienok alebo uplynutie doby odkladu, po ktorej je aktuálna "
"úloha ukončená.</p></body></html>"

#. i18n: ectx: property (text), widget (QCheckBox, kcfg_SchedulerWeather)
#: ekos/scheduler/opsweathersettings.ui:46
#, kde-format
msgid "Weather grace period"
msgstr "Ochranná lehota počasia"

#. i18n: ectx: property (toolTip), widget (QSpinBox, kcfg_SchedulerWeatherGracePeriod)
#. i18n: ectx: label, entry (SchedulerWeatherGracePeriod), group (Scheduler)
#: ekos/scheduler/opsweathersettings.ui:55 kstars.kcfg:3567
#, kde-format
msgid ""
"Wait this many minutes for the weather to improve before giving up. Set to 0 "
"to wait indefinitely (scheduler keeps monitoring until weather improves)."
msgstr ""
"Čakajte toľto minút na zlepšenie počasia pred vzdaním sa. Nastavte na 0 pre "
"čakanie na neurčito (plánovač pokračuje v monitorovaní, kým sa počasie "
"nezlepší)."

#. i18n: ectx: property (toolTip), widget (QLabel, label)
#: ekos/scheduler/opsweathersettings.ui:96
#, kde-format
msgid ""
"<html><head/><body><p>Wait this many seconds when detecting weather alert "
"before starting observatory shutdown.</p></body></html>"
msgstr ""
"<html><head/><body><p>Vynútiť hodnotu teploty pred zachytením obrázku</p></"
"body></html>"

#. i18n: ectx: property (text), widget (QLabel, label)
#: ekos/scheduler/opsweathersettings.ui:99
#, kde-format
msgid "Weather Alert  Shutdown Delay:"
msgstr "Výstraha počasia  Oneskorenie vypnutia:"

#. i18n: ectx: property (text), widget (QLabel, label_2)
#: ekos/scheduler/opsweathersettings.ui:140
#, kde-format
msgid "Standalone Safety Monitor Driver:"
msgstr "Samostatný ovládač bezpečnostného monitora:"

#. i18n: ectx: property (toolTip), widget (QLineEdit, kcfg_SchedulerSafetyMonitorConnectionString)
#. i18n: ectx: label, entry (SchedulerSafetyMonitorConnectionString), group (Scheduler)
#: ekos/scheduler/opsweathersettings.ui:147 kstars.kcfg:3575
#, kde-format
msgid ""
"Connection string for the INDI Safety Monitor driver. The scheduler uses "
"this to continuously monitor safety conditions and evaluate whether it is "
"safe to operate the observatory."
msgstr ""
"Reťazec pripojenia pre ovládač bezpečnostného monitora INDI. Plánovač ho "
"používa na nepretržité monitorovanie bezpečnostných podmienok a hodnotenie, "
"či je bezpečné prevádzkovať observatórium."

#. i18n: ectx: property (placeholderText), widget (QLineEdit, kcfg_SchedulerSafetyMonitorConnectionString)
#: ekos/scheduler/opsweathersettings.ui:150
#, kde-format
msgid "localhost:7624"
msgstr "localhost"

#: ekos/scheduler/scheduler.cpp:132
#, kde-format
msgid "Follower"
msgstr "Sledovač"

#: ekos/scheduler/scheduler.cpp:159
#, kde-format
msgid ""
"Job scheduler list.\n"
"Click to select a job in the list.\n"
"Double click to edit a job with the left-hand fields.\n"
msgstr ""
"Zoznam plánovača úloh.\n"
"Kliknite pre výber úlohy v zozname.\n"
"Dvojitým kliknutím upravíte úlohu pomocou polí vľavo.\n"

#: ekos/scheduler/scheduler.cpp:167
#, kde-format
msgid ""
"Current status of the job, managed by the Scheduler.\n"
"If invalid, the Scheduler was not able to find a proper observation time for "
"the target.\n"
"If aborted, the Scheduler missed the scheduled time or encountered "
"transitory issues and will reschedule the job.\n"
"If complete, the Scheduler verified that all sequence captures requested "
"were stored, including repeats."
msgstr ""
"Aktuálny stav úlohy, spravovaný Plánovačom.\n"
"Ak je neplatný, Plánovač nemohol nájsť vhodný čas pozorovania pre cieľ.\n"
"Ak bol prerušený, Plánovač zmeškal naplánovaný čas alebo narazil na "
"prechodné problémy a prerozvrhnete úlohu.\n"
"Ak je dokončený, Plánovač overil, že všetky požadované nasnímania sekvencie "
"boli uložené vrátane opakovaní."

#: ekos/scheduler/scheduler.cpp:172
#, kde-format
msgid ""
"Current altitude of the target of the job.\n"
"A rising target is indicated with an arrow going up.\n"
"A setting target is indicated with an arrow going down."
msgstr ""
"Aktuálna výška cieľa úlohy.\n"
"Stúpajúci cieľ je označený šípkou nahor.\n"
"Klesajúci cieľ je označený šípkou nadol."

#: ekos/scheduler/scheduler.cpp:176
#, kde-format
msgid ""
"Startup time of the job, as estimated by the Scheduler.\n"
"The altitude at startup, if available, is displayed too.\n"
"Fixed time from user or culmination time is marked with a chronometer symbol."
msgstr ""
"Čas spustenia úlohy, odhadovaný plánovačom.\n"
"Zobrazí sa aj výška pri spustení, ak je k dispozícii.\n"
"Pevný čas od používateľa alebo čas kulminácii je označený symbolom stopiek."

#: ekos/scheduler/scheduler.cpp:180
#, kde-format
msgid ""
"Completion time for the job, as estimated by the Scheduler.\n"
"You may specify a fixed time to limit duration of looping jobs. A warning "
"symbol indicates the altitude at completion may cause the job to abort "
"before completion.\n"
msgstr ""
"Čas dokončenia úlohy, odhadovaný plánovačom.\n"
"Môžete zadať pevný čas na obmedzenie doby trvania opakujúcich sa úloh. "
"Symbol upozornenia naznačuje, že výška pri dokončení môže spôsobiť "
"prerušenie úlohy pred dokončením.\n"

#: ekos/scheduler/scheduler.cpp:184 ekos/scheduler/scheduler.cpp:1979
#, kde-format
msgid ""
"Count of captures stored for the job, based on its sequence job.\n"
"This is a summary, additional specific frame types may be required to "
"complete the job."
msgstr ""
"Počet nasnímaní uložených pre úlohu na základe jej sekvenčnej úlohy.\n"
"Toto je súhrn, na dokončenie úlohy môžu byť potrebné ďalšie špecifické typy "
"rámcov."

#: ekos/scheduler/scheduler.cpp:192
#, kde-format
msgid ""
"Remove selected job from the observation list.\n"
"Job properties are copied in the edition fields before removal."
msgstr ""
"Odstrániť vybranú úlohu zo zoznamu pozorovaní.\n"
"Vlastnosti úlohy sú pred odstránením skopírované do polí na úpravu."

#: ekos/scheduler/scheduler.cpp:196
#, kde-format
msgid "Move selected job one line up in the list.\n"
msgstr "Presunúť vybranú úlohu o jeden riadok nahor v zozname.\n"

#: ekos/scheduler/scheduler.cpp:199
#, kde-format
msgid "Move selected job one line down in the list.\n"
msgstr "Presunúť vybranú úlohu o jeden riadok nadol v zozname.\n"

#: ekos/scheduler/scheduler.cpp:203
#, kde-format
msgid "Reset state and force reevaluation of all observation jobs."
msgstr "Obnoviť stav a vynutiť prehodnotenie všetkých pozorovacích úloh."

#: ekos/scheduler/scheduler.cpp:207
#, kde-format
msgid ""
"Reset state and sort observation jobs per altitude and movement in sky, "
"using the start time of the first job.\n"
"This action sorts setting targets before rising targets, and may help "
"scheduling when starting your observation.\n"
"Note the algorithm first calculates all altitudes using the same time, then "
"evaluates jobs."
msgstr ""
"Obnoviť stav a zoradiť pozorovacie úlohy podľa výšky a pohybu na oblohe "
"pomocou času spustenia prvej úlohy.\n"
"Táto akcia zoradí klesajúce ciele pred stúpajúcimi a môže pomôcť pri "
"plánovaní pri začatí pozorovania.\n"
"Poznámka: algoritmus najskôr vypočíta všetky výšky pomocou rovnakého času, "
"potom vyhodnotí úlohy."

#: ekos/scheduler/scheduler.cpp:511 ekos/scheduler/scheduler.cpp:2449
#: ekos/scheduler/schedulerprocess.cpp:3520
#, kde-format
msgid ""
"Warning: The Classic scheduler algorithm has been retired. Switching you to "
"the Greedy algorithm."
msgstr ""
"Upozornenie: Klasický algoritmus plánovača bol vyradený. Prepína sa na "
"algoritmus Chamtivý."

