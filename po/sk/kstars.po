#: kstars.kcfg:3687
#, kde-format
msgid "Display Mount RA on the Analyze Statistics Plot."
msgstr "Zobrazovať RA montáže na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeMountDEC), group (Analyze)
#: kstars.kcfg:3691
#, kde-format
msgid "Display Mount DEC on the Analyze Statistics Plot."
msgstr "Zobrazovať DEC montáže na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeMountHA), group (Analyze)
#: kstars.kcfg:3695
#, kde-format
msgid "Display Mount Hour Angle on the Analyze Statistics Plot."
msgstr "Zobrazovať hodinový uhol montáže na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeAz), group (Analyze)
#: kstars.kcfg:3699
#, kde-format
msgid "Display Azimuth on the Analyze Statistics Plot."
msgstr "Zobrazovať azimut na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzeAlt), group (Analyze)
#: kstars.kcfg:3703
#, kde-format
msgid "Display Altitude on the Analyze Statistics Plot."
msgstr "Zobrazovať výšku na grafe štatistík Analyze."

#. i18n: ectx: whatsthis, entry (AnalyzePierSide), group (Analyze)
#: kstars.kcfg:3707
#, kde-format
msgid "Display PierSide on the Analyze Statistics Plot."
msgstr "Zobrazovať stranu piliera na grafe štatistík Analyze."

#. i18n: ectx: label, entry (AnalyzeStatsYAxis), group (Analyze)
#: kstars.kcfg:3711
#, kde-format
