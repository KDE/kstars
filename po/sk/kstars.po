msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QLabel, label_6)
#: ekos/capture/rotatorsettings.ui:333
#, kde-format
msgid ""
"<html><head/><body><p><span style=\" font-weight:600;\">Flip Policy</span> "
"determines how the rotator reacts after a flip or if the result of a solved "
"reference image reports a different pierside respective to the actual mount "
"pierside.</p><p>Flip Policy can be altered in <span style=\" font-weight:600;"
"\">Align Options</span><span style=\" font-size:12pt;\"> under &quot;Rotator "
"Settings&quot;.</span></p></body></html>"
msgstr ""
"<html><head/><body><p><span style=\" font-weight:600;\">Zásada prevrátenia</"
"span> určuje, ako rotátor reaguje po prevrátení alebo ak výsledok "
"vyriešeného referenčného snímku hlási inú stranu piliera ako skutočná montáž."
"</p><p>Zásadu prevrátenia možno zmeniť v <span style=\" font-weight:600;"
"\">Možnostiach zarovnávania</span><span style=\" font-size:12pt;\"> pod "
"&quot;Nastaveniami rotátora&quot;.</span></p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_6)
#: ekos/capture/rotatorsettings.ui:336
#, kde-format
