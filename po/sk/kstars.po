msgstr "Tmavá snímka"

#. i18n: ectx: property (text), widget (QLabel, label_18)
#: ekos/focus/opsfocussettings.ui:182
#, kde-format
msgid "Guide Settle:"
msgstr "Stabilizácia navádzania:"

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusBoxSize)
#: ekos/focus/opsfocussettings.ui:201
#, kde-format
msgid "<html><head/><body><p>Size of the subframe in pixels.</p></body></html>"
msgstr ""
"<html><head/><body><p>Vynútiť hodnotu teploty pred zachytením obrázku</p></"
"body></html>"

#. i18n: ectx: property (suffix), widget (QSpinBox, focusBoxSize)
#. i18n: ectx: property (suffix), widget (QSpinBox, focusMosaicSpace)
#: ekos/focus/opsfocussettings.ui:204 ekos/focus/opsfocussettings.ui:356
#, kde-format
msgid " px"
msgstr " x "

#. i18n: ectx: property (toolTip), widget (QCheckBox, focusSuspendGuiding)
#: ekos/focus/opsfocussettings.ui:232
#, kde-format
msgid "Suspend Guiding while autofocus in progress"
msgstr "Pozastaviť navádzanie, kým prebieha automatické ostrenie"

#. i18n: ectx: property (text), widget (QCheckBox, focusSuspendGuiding)
#: ekos/focus/opsfocussettings.ui:235
#, kde-format
msgid "Suspend Guiding"
msgstr "Pozastaviť navádzanie"

#. i18n: ectx: property (text), widget (QLabel, label)
#: ekos/focus/opsfocussettings.ui:248
#, kde-format
msgid "Optimize AF:"
msgstr "Optimalizovať AF:"

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusAFOptimize)
#: ekos/focus/opsfocussettings.ui:261
#, kde-format
msgid ""
"<html><head/><body><p>Create an &quot;optimization zone&quot; of this many "
"seconds. When an automated Autofocus run is requested by another process, e."
"g. Scheduler or Capture, a check is performed on the timestamp of the last "
"successful Autofocus for that filter. If we are within the optimization zone "
"then no Autofocus is run; if outside the zone, Autofocus is run as normal.</"
"p><p>Note that filter offsets and Adaptive Focus settings are always "
"honoured.</p><p>Set to zero to disable this feature.</p><p>NOTE: manually "
"initiated runs will always be performed.</p><p>This is currently an "
"experimental feature enabled for Linear and Linear 1 Pass only.</p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Vytvorí &quot;optimalizačnú zónu&quot; tohto počtu "
"sekúnd. Keď iný proces, napr. Plánovač alebo Snímanie, požaduje automatický "
"beh automatického zaostrovania, vykoná sa kontrola časovej pečiatky "
"posledného úspešného automatického zaostrovania pre daný filter. Ak sme v "
"rámci optimalizačnej zóny, žiadne automatické zaostrovanie sa nespustí; ak "
"sme mimo zóny, automatické zaostrovanie prebehne normálne.</p><p>Všimnite "
"si, že offsety filtrov a nastavenia Adaptívneho zaostrovania sú vždy "
"dodržiavané.</p><p>Nastavte na nulu pre deaktiváciu tejto funkcie.</"
"p><p>POZNÁMKA: manuálne iniciované behy budú vždy vykonané.</p><p>Toto je v "
"súčasnosti experimentálna funkcia povolená iba pre Linear a Linear 1 Pass.</"
"p></body></html>"

#. i18n: ectx: property (toolTip), widget (QSpinBox, maxFocusFrameFiles)
#: ekos/focus/opsfocussettings.ui:277
#, kde-format
msgid ""
"Upper limit how many focus frames should be kept on disk. Set to -1 to allow "
"arbitrary many files."
msgstr ""
"Horný limit počtu zaostrovacích rámcov, ktoré sa uchovávajú na disku. "
"Nastavte na -1 pre ľubovoľný počet súborov."

#. i18n: ectx: property (text), widget (QLabel, label_2)
#: ekos/focus/opsfocussettings.ui:290
#, kde-format
msgid "Max. Stored Frames:"
msgstr "Max. uložených rámcov:"

#. i18n: ectx: property (toolTip), widget (QRadioButton, focusMosaicMaskRB)
#: ekos/focus/opsfocussettings.ui:315
#, kde-format
msgid ""
"<html><head/><body><p>Aberration inspector style mask with a 3x3 mosaic "
"formed with tiles from the center, the corners and the edges.</p></body></"
"html>"
msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, focusMosaicMaskRB)
#: ekos/focus/opsfocussettings.ui:318
#, kde-format
msgid "Mosaic Mask:"
msgstr "Maska mozaiky:"

#. i18n: ectx: property (toolTip), widget (QRadioButton, focusRingMaskRB)
#: ekos/focus/opsfocussettings.ui:331
#, no-c-format, kde-format
msgid ""
"<html><head/><body><p>During Full Field focusing, this controls the size of "
"an Annulus centred at the middle of the sensor to include for processing. "
"Set inner % to zero to include the centre of the sensor and set outer % to "
"100 to include the outer edges of the sensor. </p></body></html>"
msgstr ""
"<html><head/><body><p>Počas zaostrovania plného poľa toto ovláda veľkosť "
"prstenca vycentrovaného v strede senzora na zahrnutie do spracovania. "
"Nastavte vnútorné % na nulu pre zahrnutie stredu senzora a vonkajšie % na "
"100 pre zahrnutie vonkajších okrajov senzora.</p></body></html>"

#. i18n: ectx: property (text), widget (QRadioButton, focusRingMaskRB)
#: ekos/focus/opsfocussettings.ui:334
#, kde-format
msgid "Ring Mask:"
msgstr "Prstencová maska:"

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusMosaicSpace)
#: ekos/focus/opsfocussettings.ui:350
#, kde-format
msgid ""
"<html><head/><body><p>Size of the separator between the tiles.</p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Vynútiť hodnotu teploty pred zachytením obrázku</p></"
"body></html>"

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusMosaicTileWidth)
#: ekos/focus/opsfocussettings.ui:375
#, kde-format
msgid ""
"<html><head/><body><p>Tiles are squares with an edge length calculated by "
"the given percentage of the image width. The percentage is limited such that "
"the tile size does not exceed one third of the shorter side of the image (in "
"most cases, it's height).</p></body></html>"
msgstr ""
"<html><head/><body><p>Dlaždice sú štvorce s dĺžkou strany vypočítanou z "
"daného percentuálneho podielu šírky snímky. Percento je obmedzené tak, aby "
"veľkosť dlaždice nepresahovala jednu tretinu kratšej strany snímky (vo "
"väčšine prípadov je to výška).</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, focusFullFieldInnerRadius)
#: ekos/focus/opsfocussettings.ui:409
#, kde-format
msgid ""
"<html><head/><body><p>Diameter of the inner circle to be excluded from "
"focusing (e.g. a centered galaxy or star cluster). The diameter is given as "
"percentage of the image diagonal. Set to zero to include the centre of the "
"sensor.</p></body></html>"
msgstr ""
"<html><head/><body><p>Priemer vnútorného kruhu, ktorý sa má vylúčiť zo "
"zaostrovania (napr. centrovaná galaxia alebo hviezdna kupa). Priemer je daný "
"ako percentuálny podiel uhlopriečky snímky. Nastavte na nulu pre zahrnutie "
"stredu senzora.</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, focusSpacerLabel)
#: ekos/focus/opsfocussettings.ui:434
#, kde-format
msgid "Spacer:"
msgstr "Medzera:"

#. i18n: ectx: property (toolTip), widget (QRadioButton, focusNoMaskRB)
#: ekos/focus/opsfocussettings.ui:450
#, kde-format
msgid "All stars are used for focusing."
msgstr "Na zaostrovanie sa používajú všetky hviezdy."

#. i18n: ectx: property (text), widget (QRadioButton, focusNoMaskRB)
#: ekos/focus/opsfocussettings.ui:453
#, kde-format
msgid "Use all stars for focusing"
msgstr "Použiť všetky hviezdy na zaostrovanie"

#. i18n: ectx: property (toolTip), widget (QDoubleSpinBox, focusFullFieldOuterRadius)
#: ekos/focus/opsfocussettings.ui:469
#, no-c-format, kde-format
msgid ""
"<html><head/><body><p>Diameter of the outer circle to be excluded from "
"focusing. The diameter is given as percentage of the image diagonal. Set to "
"100% to include the outer edges of the sensor. </p></body></html>"
msgstr ""
"<html><head/><body><p>Priemer vonkajšieho kruhu, ktorý sa má vylúčiť zo "
"zaostrovania. Priemer je daný ako percentuálny podiel uhlopriečky snímky. "
"Nastavte na 100 % pre zahrnutie vonkajších okrajov senzora. </p></body></"
"html>"

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusAdaptiveMinMove)
#: ekos/focus/opsfocussettings.ui:530
#, kde-format
msgid ""
"<html><head/><body><p>The minimum size of an adaptive focus change that will "
"be sent to the focuser.</p></body></html>"
msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (suffix), widget (QSpinBox, focusAdaptiveMinMove)
#. i18n: ectx: property (suffix), widget (QSpinBox, focusAdaptiveMaxMove)
#: ekos/focus/opsfocussettings.ui:533 ekos/focus/opsfocussettings.ui:558
#, kde-format
msgid " ticks"
msgstr " tikoty"

#. i18n: ectx: property (toolTip), widget (QSpinBox, focusAdaptiveMaxMove)
#: ekos/focus/opsfocussettings.ui:555
#, kde-format
msgid ""
"<html><head/><body><p>The maximum total Adaptive focuser movement between "
"Autofocus runs.  If this value is hit,  adaptive focusing is suspended.  The "
"purpose of this control is to handle runaway adaptive focusing.</p></body></"
"html>"
msgstr ""
"<html><head/><body><p>Maximálny celkový pohyb adaptívneho zaostrovača medzi "
"behmi automatického zaostrovania. Ak je táto hodnota dosiahnutá, adaptívne "
"zaostrovanie je pozastavené. Účelom tohto ovládača je zvládnuť "
"nekontrolované adaptívne zaostrovanie.</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QCheckBox, focusAdaptive)
#: ekos/focus/opsfocussettings.ui:580
#, kde-format
msgid ""
"<html><head/><body><p>Enable Adaptive Focus between subframes. This is an "
"experimental feature.</p></body></html>"
msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (toolTip), widget (QLabel, label_7)
#: ekos/focus/opsfocussettings.ui:596
#, kde-format
msgid ""
"<html><head/><body><p>Minimum focuser movement when using Adaptive Focus.</"
"p></body></html>"
msgstr "<html><head/><body><p>Iba vyhodnotiť úlohy</p></body></html>"

#. i18n: ectx: property (text), widget (QLabel, label_7)
#: ekos/focus/opsfocussettings.ui:599
#, kde-format
msgid "Min Move:"
msgstr "Minimálny impulz"

#. i18n: ectx: property (toolTip), widget (QCheckBox, focusAdaptStart)
#: ekos/focus/opsfocussettings.ui:618
#, kde-format
msgid ""
"<html><head/><body><p>Adapt the Autofocus start position based on filter and "
