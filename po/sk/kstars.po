#. i18n: ectx: property (toolTip), widget (QLineEdit, recordDirectoryEdit)
#. i18n: ectx: property (toolTip), widget (QLabel, label_2)
#: indi/recordingoptions.ui:59 indi/recordingoptions.ui:144
#, kde-format
msgid ""
"<html><head/><body>\n"
"<p>Set SER video <b>remote</b> directory name. If INDI server is running "
"locally, then a local directory can be selected. However, if you are "
"connected to a remote INDI server, then the directory must be a valid "
"directory on the remote file system where it is saved.</p>\n"
"<p>Record directories may contain some patterns to make them dynamic:</p>\n"
"<ul>\n"
"<li><b>_D_</b> for the date in YYYY-MM-DD.</li>\n"
"<li><b>_H_</b> for time in HH:MM:SS.</li>\n"
"<li><b>_T_</b> for ISO8601 time stamp.</li>\n"
"<li><b>_F_</b> for filter name, if any.</li>\n"
"</ul>\n"
"</body></html>"
msgstr ""
"<html><head/><body>\n"
"<p>Nastaviť názov <b>vzdialeného</b> adresára videa SER. Ak server INDI beží "
"lokálne, možno vybrať lokálny adresár. Ak ste však pripojení k vzdialenému "
"serveru INDI, adresár musí byť platný adresár na vzdialenom súborovom "
"systéme, kde sa uloží.</p>\n"
"<p>Adresáre záznamu môžu obsahovať vzory pre ich dynamické nastavenie:</p>\n"
"<ul>\n"
"<li><b>_D_</b> pre dátum vo formáte RRRR-MM-DD.</li>\n"
"<li><b>_H_</b> pre čas vo formáte HH:MM:SS.</li>\n"
"<li><b>_T_</b> pre časovú pečiatku ISO8601.</li>\n"
"<li><b>_F_</b> pre názov filtra, ak existuje.</li>\n"
"</ul>\n"
"</body></html>"

#. i18n: ectx: property (toolTip), widget (QPushButton, selectDirB)
#: indi/recordingoptions.ui:78
#, kde-format
msgid "Play/Pause"
msgstr "Spustiť/Pozastaviť"

