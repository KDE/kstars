#: ekos/auxiliary/opticaltrains.ui:229
#, kde-format
msgid ""
"<html><head/><body><p>Select if any reducer or barlow is used in the train.</"
"p><p><span style=\" font-weight:600;\">Reducer:</span> If the value is less "
"than 1.0x, this element is considered as a reducer (focal length is "
"decreased by this factor).</p><p><span style=\" font-weight:600;\">Barlow</"
"span>: If the value is over 1.0x, then it is considered a barlow element "
"(focal length is increased by this factor).</p></body></html>"
msgstr ""
"<html><head/><body><p>Vyberte, ak je v trase použitý reduktor alebo Barlow.</"
"p><p><span style=\" font-weight:600;\">Reduktor:</span> Ak je hodnota menšia "
"ako 1,0x, tento prvok sa považuje za reduktor (ohnisková vzdialenosť je "
"znížená týmto faktorom).</p><p><span style=\" font-weight:600;\">Barlow</"
"span>: Ak je hodnota väčšia ako 1,0x, považuje sa to za Barlowov prvok "
"(ohnisková vzdialenosť je zvýšená týmto faktorom).</p></body></html>"

